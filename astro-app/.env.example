# CMS Configuration
# Copy this file to .env and fill in your values

# ============================================
# Sanity CMS (推荐 - 有免费额度)
# ============================================
# 你的 Sanity Project ID
SANITY_PROJECT_ID=your_project_id_here

# Dataset 名称 (默认: production)
SANITY_DATASET=production

# API Token (Settings > API > Tokens)
# 需要 "Editor" 或 "Administrator" 权限用于数据迁移
SANITY_API_TOKEN=your_api_token_here

# ============================================
# Contentful CMS (备选 - 无免费计划)
# ============================================
# Contentful Space ID
CONTENTFUL_SPACE_ID=

# Content Delivery API Token
CONTENTFUL_DELIVERY_TOKEN=

# Content Preview API Token (可选)
CONTENTFUL_PREVIEW_TOKEN=

# Environment (默认: master)
CONTENTFUL_ENVIRONMENT=master

# Management Token (仅用于数据迁移)
CONTENTFUL_MANAGEMENT_TOKEN=
