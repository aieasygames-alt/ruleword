---
import '../styles/global.css'

interface Props {
  title: string
  description?: string
  keywords?: string
  canonicalPath?: string
  ogImage?: string
  gameType?: string
  isHomePage?: boolean
  breadcrumbItems?: Array<{name: string; url: string}>
}

const {
  title,
  description = 'Play 103+ free online games: Wordle, Sudoku, 2048, Tetris, Chess, Mahjong, Typing Test, Aim Trainer and more! 7 categories, no download required.',
  keywords = 'free online games, puzzle games, word games, logic games, wordle, sudoku, 2048, tetris, chess, mahjong, typing test, aim trainer, memory games, arcade games, strategy games',
  canonicalPath = '/',
  ogImage = '/icons/og-image.png',
  gameType,
  isHomePage = false,
  breadcrumbItems
} = Astro.props

const canonicalUrl = `https://ruleword.com${canonicalPath}`
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `https://ruleword.com${ogImage}`
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <!-- Theme Initialization - Must run before any CSS loads -->
    <script is:inline>
      (function() {
        const html = document.documentElement;
        const savedTheme = localStorage.getItem('ruleword-theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;

        // Set theme immediately
        if (savedTheme === 'light' || (!savedTheme && !prefersDark)) {
          html.classList.remove('dark');
        } else {
          html.classList.add('dark');
        }
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="RuleWord" />
    <meta name="robots" content="index, follow" />

    <!-- Theme Color -->
    <meta name="theme-color" content="#0f172a" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content={gameType ? 'game' : 'website'} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="RuleWord" />
    <meta property="og:image" content={ogImageUrl} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@ruleword" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icons/icon-192.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/icons/icon-192.png" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Nunito+Sans:wght@600;700;800&display=swap" rel="stylesheet" />

    <!-- Preload hints for performance -->
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
    <link rel="preconnect" href="https://www.googletagmanager.com" />

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-5396G592M6"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-5396G592M6');
    </script>

    <!-- JSON-LD Structured Data -->
    {gameType ? (
      <>
        <script type="application/ld+json" set:html={JSON.stringify({
          "@context": "https://schema.org",
          "@type": "VideoGame",
          "name": title.split(' - ')[0],
          "description": description,
          "url": canonicalUrl,
          "applicationCategory": "GameApplication",
          "gamePlatform": ["Web Browser", "Mobile Web"],
          "operatingSystem": "Any",
          "genre": gameType,
          "offers": {
            "@type": "Offer",
            "price": "0",
            "priceCurrency": "USD"
          }
        })} />
        {/* Breadcrumb Schema for Game Pages */}
        {breadcrumbItems && breadcrumbItems.length > 0 && (
          <script type="application/ld+json" set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "BreadcrumbList",
            "itemListElement": breadcrumbItems.map((item, index) => ({
              "@type": "ListItem",
              "position": index + 1,
              "name": item.name,
              "item": `https://ruleword.com${item.url}`
            }))
          })} />
        )}
      </>
    ) : (
      <>
        <script type="application/ld+json" set:html={JSON.stringify({
          "@context": "https://schema.org",
          "@type": "WebApplication",
          "name": "RuleWord",
          "description": "Play 103+ free online games: Wordle, Sudoku, 2048, Tetris, Chess, Mahjong, Typing Test and more! 7 categories of puzzle, word, logic, strategy, arcade, memory and skill games.",
          "url": "https://ruleword.com",
          "applicationCategory": "GameApplication",
          "operatingSystem": "Any",
          "offers": {
            "@type": "Offer",
            "price": "0",
            "priceCurrency": "USD"
          },
          "genre": ["Puzzle", "Word Game", "Arcade", "Strategy", "Logic", "Memory", "Skill"]
        })} />
        {/* FAQ Schema for Homepage */}
        {isHomePage && (
          <script type="application/ld+json" set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "FAQPage",
            "mainEntity": [
              {
                "@type": "Question",
                "name": "Are all games on RuleWord really free?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Yes! All 103+ games on RuleWord are completely free to play with no hidden costs, subscriptions, or in-app purchases. We believe gaming should be accessible to everyone."
                }
              },
              {
                "@type": "Question",
                "name": "Do I need to create an account to play?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "No registration required! Simply visit any game page and start playing instantly. Your progress and high scores are saved locally in your browser using localStorage."
                }
              },
              {
                "@type": "Question",
                "name": "Can I play RuleWord games on mobile devices?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Absolutely! All games are fully responsive and work on desktop computers, tablets, and mobile phones. No app download needed - everything runs in your browser."
                }
              },
              {
                "@type": "Question",
                "name": "What types of games are available on RuleWord?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "We offer 7 categories of games: Word Games (Wordle, Spelling Bee, Word Search), Logic & Numbers (Sudoku, 2048, Nonogram), Strategy (Chess, Gomoku, Reversi), Arcade (Tetris, Snake, Pac-Man), Memory & Reflex games, Skill games, and various Puzzles."
                }
              },
              {
                "@type": "Question",
                "name": "How often are new games added?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "We add new games regularly, typically several new games each month. Check back often for fresh challenges and don't forget to check the Featured section for our latest additions!"
                }
              }
            ]
          })} />
        )}
        {/* Breadcrumb Schema */}
        {breadcrumbItems && breadcrumbItems.length > 0 && (
          <script type="application/ld+json" set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "BreadcrumbList",
            "itemListElement": breadcrumbItems.map((item, index) => ({
              "@type": "ListItem",
              "position": index + 1,
              "name": item.name,
              "item": `https://ruleword.com${item.url}`
            }))
          })} />
        )}
        {/* Organization Schema for Homepage */}
        {isHomePage && (
          <script type="application/ld+json" set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "Organization",
            "name": "RuleWord",
            "url": "https://ruleword.com",
            "logo": "https://ruleword.com/icons/icon-512.png",
            "description": "Free online puzzle games platform with 103+ games across 7 categories",
            "sameAs": [
              "https://twitter.com/ruleword"
            ]
          })} />
        )}
      </>
    )}
    <!-- Browser Upgrade Notice -->
    <style>
      .browser-upgrade {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 99999;
        padding: 20px;
      }
      .browser-upgrade-content {
        max-width: 600px;
        text-align: center;
        animation: fadeIn 0.5s ease;
      }
      .browser-upgrade-content h1 {
        font-size: 2rem;
        margin-bottom: 1rem;
        color: #f8fafc;
      }
      .browser-upgrade-content p {
        font-size: 1.1rem;
        line-height: 1.6;
        color: #cbd5e1;
        margin-bottom: 1.5rem;
      }
      .browser-upgrade-content a {
        display: inline-block;
        padding: 12px 24px;
        margin: 8px;
        background: #3b82f6;
        color: white;
        text-decoration: none;
        border-radius: 8px;
        font-weight: 600;
        transition: background 0.3s;
      }
      .browser-upgrade-content a:hover {
        background: #2563eb;
      }
      @keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
      }
    </style>
    <script>
      (function() {
        // Check for Chrome 86 or older
        const isChrome = /Chrome\/(\d+)/.test(navigator.userAgent);
        const chromeVersion = isChrome ? parseInt(/Chrome\/(\d+)/.exec(navigator.userAgent)[1]) : Infinity;
        const isOldChrome = isChrome && chromeVersion <= 86;

        // Check for other old browsers
        const isOldSafari = /Version\/(\d+)/.test(navigator.userAgent) && parseInt(/Version\/(\d+)/.exec(navigator.userAgent)[1]) < 14;
        const isOldFirefox = /Firefox\/(\d+)/.test(navigator.userAgent) && parseInt(/Firefox\/(\d+)/.exec(navigator.userAgent)[1]) < 78;
        const isOldEdge = /Edg\/(\d+)/.test(navigator.userAgent) && parseInt(/Edg\/(\d+)/.exec(navigator.userAgent)[1]) < 86;

        if (isOldChrome || isOldSafari || isOldFirefox || isOldEdge) {
          document.addEventListener('DOMContentLoaded', function() {
            const html = `
        <div class="browser-upgrade">
          <div class="browser-upgrade-content">
            <h1>🚀 Browser Update Required</h1>
            <p>Your browser version is too old to display this website correctly. Please update your browser to the latest version for the best experience.</p>
            <p><strong>Recommended browsers:</strong></p>
            <a href="https://www.google.com/chrome/" target="_blank" rel="noopener">Download Chrome</a>
            <a href="https://www.microsoft.com/edge" target="_blank" rel="noopener">Download Edge</a>
            <a href="https://www.mozilla.org/firefox/" target="_blank" rel="noopener">Download Firefox</a>
            <a href="https://www.apple.com/safari/" target="_blank" rel="noopener">Download Safari</a>
          </div>
        </div>
      `;
            document.body.insertAdjacentHTML('afterbegin', html);
          });
        }
      })();
    </script>
  </head>
  <body class="bg-gray-50 text-gray-900 dark:bg-slate-900 dark:text-white">
    <slot />
  </body>
</html>
