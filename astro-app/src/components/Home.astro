---
// Home.astro - Astro 原生首页组件，无需 React
import { games, categories } from '../data/games'

const language = 'en' // 默认语言
---

<div class="min-h-screen bg-slate-950 text-white">
  <!-- Header -->
  <header class="sticky top-0 z-50 bg-slate-950/90 border-b border-slate-800 backdrop-blur-xl">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="flex items-center justify-between h-16">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-green-400 to-emerald-600 flex items-center justify-center text-white font-bold text-xl shadow-lg shadow-green-500/25">
            R
          </div>
          <div>
            <h1 class="text-xl font-bold tracking-tight">RuleWord</h1>
            <p class="text-xs text-slate-400 -mt-0.5">{games.length}+ Free Games</p>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- Hero -->
  <div class="relative overflow-hidden bg-gradient-to-b from-slate-900 to-slate-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-12 sm:py-16 text-center">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-4 tracking-tight">
        Free Online Games
      </h2>
      <p class="text-lg sm:text-xl max-w-2xl mx-auto text-slate-400 mb-8">
        Classic puzzles, strategy games, arcade fun. No downloads, play instantly.
      </p>
    </div>
  </div>

  <!-- Main Content -->
  <main class="max-w-7xl mx-auto px-4 sm:px-6 pb-16">
    <!-- Category Tabs -->
    <div class="sticky top-16 z-40 py-4 bg-slate-950/95 backdrop-blur-sm">
      <div class="flex gap-2 overflow-x-auto pb-2">
        {categories.map(cat => (
          <button
            class="px-4 py-2 rounded-xl whitespace-nowrap font-medium transition-all flex items-center gap-2 bg-green-500 text-white shadow-lg shadow-green-500/25"
            data-category={cat.id}
          >
            <span>{cat.icon}</span>
            <span>{cat.name}</span>
          </button>
        ))}
      </div>
    </div>

    <!-- Featured Section -->
    <section class="mt-8 mb-12">
      <div class="flex items-center gap-3 mb-6">
        <span class="text-2xl">⭐</span>
        <h3 class="text-xl font-bold">Featured Games</h3>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
        {games.filter(g => g.featured).map(game => (
          <a
            href={`/games/${game.slug}/`}
            class={`group relative overflow-hidden rounded-2xl aspect-square p-5 text-left transition-all duration-300 hover:scale-[1.02] hover:shadow-2xl bg-gradient-to-br ${game.color}`}
          >
            <div class="relative z-10 h-full flex flex-col justify-between">
              <div class="text-4xl lg:text-5xl">{game.icon}</div>
              <div>
                <h4 class="font-bold text-white text-lg mb-1">{game.name}</h4>
                <p class="text-white/80 text-sm line-clamp-2">{game.desc}</p>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- All Games -->
    <section>
      <div class="flex items-center gap-3 mb-6">
        <span class="text-2xl">🎮</span>
        <h3 class="text-xl font-bold">All Games</h3>
        <span class="text-sm text-slate-400">{games.length} games</span>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {games.map(game => (
          <a
            href={`/games/${game.slug}/`}
            class={`group relative overflow-hidden rounded-2xl p-5 text-left transition-all duration-300 hover:shadow-xl hover:-translate-y-1 bg-slate-900/80 border border-slate-800`}
          >
            <div class="flex items-start gap-4">
              <div class={`w-14 h-14 rounded-xl bg-gradient-to-br ${game.color} flex items-center justify-center flex-shrink-0 shadow-lg transition-transform group-hover:scale-110`}>
                <span class="text-2xl">{game.icon}</span>
              </div>
              <div class="flex-1 min-w-0">
                <h4 class="font-bold text-lg mb-1">{game.name}</h4>
                <p class="text-sm text-slate-400 line-clamp-2">{game.desc}</p>
              </div>
              <svg class="w-5 h-5 text-slate-400 group-hover:text-green-500 group-hover:translate-x-1 transition-all flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
            {game.featured && (
              <div class="absolute top-3 right-3">
                <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-gradient-to-r from-amber-400 to-orange-500 text-white">
                  ⭐
                </span>
              </div>
            )}
          </a>
        ))}
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer class="border-t border-slate-800 bg-slate-900/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-8">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-green-400 to-emerald-600 flex items-center justify-center text-white font-bold text-sm">
            R
          </div>
          <span class="font-semibold text-slate-400">RuleWord</span>
        </div>
        <p class="text-sm text-slate-400">
          © 2026 RuleWord · {games.length}+ Free Games
        </p>
      </div>
    </div>
  </footer>
</div>
