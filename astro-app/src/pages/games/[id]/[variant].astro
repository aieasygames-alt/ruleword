---
// Game Variant Page - Programmatic SEO for long-tail keywords
import BaseLayout from '../../../layouts/BaseLayout.astro'
import { getAllVariants, getVariant } from '../../../data/gameVariants'
import { games } from '../../../data/games'
import { t as i18n, lang } from '../../../data/i18n'

export function getStaticPaths() {
  const variants = getAllVariants()
  return variants.map(variant => ({
    params: { id: variant.gameId, variant: variant.variant },
  }))
}

const { id, variant: variantName } = Astro.params
const variant = getVariant(id, variantName)
const game = games.find(g => g.id === id)

if (!variant || !game) {
  return Astro.redirect('/404')
}

// Get other variants for the same game
const allVariants = getAllVariants().filter(v => v.gameId === id)

// Schema for variant page
const schema = {
  "@context": "https://schema.org",
  "@type": "VideoGame",
  "name": variant.title,
  "description": variant.description,
  "genre": "Puzzle",
  "gamePlatform": "Web Browser",
  "applicationCategory": "Game",
  "operatingSystem": "Any",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
}

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://ruleword.com/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": game.name,
      "item": `https://ruleword.com/games/${game.id}/`
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": variant.variant.charAt(0).toUpperCase() + variant.variant.slice(1),
      "item": `https://ruleword.com/games/${game.id}/${variant.variant}/`
    }
  ]
}

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": `How to Play ${variant.title}`,
  "step": variant.tips?.map((tip, index) => ({
    "@type": "HowToStep",
    "position": index + 1,
    "text": tip
  })) || []
}
---

<BaseLayout title={variant.title} description={variant.description} keywords={variant.keywords}>
  <div class="min-h-screen bg-slate-950 text-white">
    <!-- Header -->
    <header class="sticky top-0 z-50 bg-slate-950/90 border-b border-slate-800 backdrop-blur-xl">
      <div class="max-w-4xl mx-auto px-4 sm:px-6">
        <div class="flex items-center justify-between h-14">
          <a href="/" class="flex items-center gap-2 hover:opacity-80 transition-opacity">
            <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-green-400 to-emerald-600 flex items-center justify-center text-white font-bold text-sm shadow-lg">
              R
            </div>
            <span class="font-semibold">Free Games Hub</span>
          </a>
          <nav class="flex items-center gap-4 text-sm">
            <a href={`/games/${game.id}/`} class="text-slate-400 hover:text-white transition-colors">
              {game.name}
            </a>
            <a href="/" class="text-slate-400 hover:text-white transition-colors">
              All Games
            </a>
          </nav>
        </div>
      </div>
    </header>

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />

    <main class="max-w-4xl mx-auto px-4 sm:px-6 py-8">
      <!-- Breadcrumb -->
      <nav class="mb-6 text-sm">
        <ol class="flex items-center gap-2 text-slate-400 flex-wrap">
          <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
          <li>/</li>
          <li><a href={`/games/${game.id}/`} class="hover:text-white transition-colors">{game.name}</a></li>
          <li>/</li>
          <li class="text-white capitalize">{variant.variant}</li>
        </ol>
      </nav>

      <!-- Hero -->
      <div class="flex items-start gap-4 mb-8">
        <div class="text-5xl">{game.icon}</div>
        <div>
          <h1 class="text-2xl sm:text-3xl font-bold mb-2">
            {variant.h1}
          </h1>
          <p class="text-slate-300">
            {variant.description}
          </p>
        </div>
      </div>

      <!-- Game Embed -->
      <div class="bg-slate-900/50 border border-slate-800 rounded-2xl overflow-hidden mb-8">
        <div class="aspect-[4/3] sm:aspect-video flex items-center justify-center bg-slate-800">
          <div class="text-center p-8">
            <div class="text-6xl mb-4">{game.icon}</div>
            <h2 class="text-xl font-semibold mb-2">{game.name} - {variant.variant.charAt(0).toUpperCase() + variant.variant.slice(1)}</h2>
            <p class="text-slate-400 mb-4">Play the full game with {variant.variant} settings</p>
            <a
              href={`/games/${game.id}/?variant=${variant.variant}`}
              class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-gradient-to-r from-green-500 to-emerald-600 hover:from-green-400 hover:to-emerald-500 font-medium transition-all"
            >
              <span>▶️</span>
              Play Now
            </a>
          </div>
        </div>
      </div>

      <!-- Variant Tips -->
      {variant.tips && variant.tips.length > 0 && (
        <section class="mb-8">
          <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
            <span>💡</span>
            Tips for {variant.variant.charAt(0).toUpperCase() + variant.variant.slice(1)} Mode
          </h2>
          <div class="bg-slate-900/50 border border-slate-800 rounded-xl p-6">
            <ul class="space-y-3">
              {variant.tips.map((tip, index) => (
                <li class="flex items-start gap-3">
                  <span class="w-6 h-6 rounded-full bg-green-500/20 text-green-400 flex items-center justify-center text-sm font-medium flex-shrink-0">
                    {index + 1}
                  </span>
                  <span class="text-slate-300">{tip}</span>
                </li>
              ))}
            </ul>
          </div>
        </section>
      )}

      <!-- Other Variants -->
      {allVariants.length > 1 && (
        <section class="mb-8">
          <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
            <span>🎮</span>
            Other {game.name} Modes
          </h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
            {allVariants.map(v => (
              <a
                href={`/games/${v.gameId}/${v.variant}/`}
                class={`group bg-slate-900/50 border rounded-xl p-4 hover:border-slate-500 transition-all text-center ${v.variant === variantName ? 'border-green-500' : 'border-slate-800'}`}
              >
                <div class="text-2xl mb-2">
                  {v.variantType === 'difficulty' && (v.variant === 'easy' ? '🟢' : v.variant === 'medium' ? '🟡' : '🔴')}
                  {v.variantType === 'size' && '📐'}
                  {v.variantType === 'mode' && '⚡'}
                </div>
                <h3 class="font-medium capitalize group-hover:text-green-400 transition-colors">
                  {v.variant}
                </h3>
                <p class="text-xs text-slate-500 mt-1 capitalize">{v.variantType}</p>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- Back to main game -->
      <section class="mb-8">
        <a
          href={`/games/${game.id}/`}
          class="group flex items-center justify-between bg-gradient-to-r from-green-900/30 to-emerald-900/30 border border-green-700/50 rounded-xl p-5 hover:border-green-500 transition-all"
        >
          <div>
            <h3 class="font-semibold group-hover:text-green-400 transition-colors">
              Play Full {game.name}
            </h3>
            <p class="text-sm text-slate-400">
              Access all features and game modes
            </p>
          </div>
          <svg class="w-5 h-5 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
      </section>

      <!-- Related Games -->
      <section>
        <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
          <span>🎯</span>
          You Might Also Like
        </h2>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          {games
            .filter(g => g.category === game.category && g.id !== game.id)
            .slice(0, 4)
            .map(g => (
              <a
                href={`/games/${g.id}/`}
                class="group bg-slate-900/50 border border-slate-800 rounded-xl p-4 hover:border-slate-600 transition-all text-center"
              >
                <div class="text-3xl mb-2">{g.icon}</div>
                <h3 class="font-medium text-sm group-hover:text-green-400 transition-colors">
                  {g.name}
                </h3>
              </a>
            ))}
        </div>
      </section>
    </main>

    <!-- Footer -->
    <footer class="border-t border-slate-800 py-6 px-4 mt-8">
      <div class="max-w-4xl mx-auto text-center text-sm text-slate-400">
        <p>© 2026 Free Games Hub · Free Online Games</p>
      </div>
    </footer>
  </div>
</BaseLayout>
