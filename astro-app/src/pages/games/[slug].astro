---
import BaseLayout from '../../layouts/BaseLayout.astro'
import GameWrapper from '../../components/GameWrapper'
import { getCollection, type CollectionEntry } from 'astro:content'
import { categories } from '../../data/games'
import { i18n, categoryI18n, type Language, languages } from '../../data/i18n'

// 在 getStaticPaths 中获取所有游戏
export async function getStaticPaths() {
  const gamesCollection = await getCollection('games')
  const allGames = gamesCollection.map(entry => entry.data)

  return gamesCollection.map(entry => ({
    params: { slug: entry.data.slug },
    props: { game: entry.data, allGames }
  }))
}

interface GameData {
  id: string
  slug: string
  icon: string
  category: 'word' | 'logic' | 'strategy' | 'arcade' | 'memory' | 'skill' | 'puzzle'
  featured?: boolean
  color: string
  en: {
    name: string
    desc: string
    howToPlay?: string
    tips?: string[]
  }
  zh?: {
    name: string
    desc: string
    howToPlay?: string
    tips?: string[]
  }
}

const { game, allGames: gamesList } = Astro.props as { game: GameData; allGames: GameData[] }

// Get language from URL parameter, default to 'en'
const urlLang = Astro.url.searchParams.get('lang') as string
const lang: Language = languages.some(l => l.code === urlLang) ? (urlLang as Language) : 'en'
const t = i18n[lang]

// Get game guide content from CMS data
const gameGuideEn = {
  intro: game.en.desc,
  howToPlay: game.en.howToPlay || '',
  tips: game.en.tips || []
}
const gameGuideZhCN = game.zh ? {
  intro: game.zh.desc,
  howToPlay: game.zh.howToPlay || game.en.howToPlay || '',
  tips: game.zh.tips || game.en.tips || []
} : gameGuideEn

// For SEO, use English as default
const gameGuide = gameGuideEn

// Get category for gameType with i18n
const category = categories.find(c => c.id === game.category)
const categoryData = categoryI18n[lang]?.[game.category]
const gameType = categoryData?.name || category?.name || 'Puzzle'

// Build keywords from game info
const keywords = `${game.en.name}, ${game.zh?.name || ''}, ${game.en.desc}, ${game.zh?.desc || ''}, free online game, puzzle game`

// Helper for localized game name
const getGameName = () => lang === 'zh-CN' || lang === 'zh-TW' ? (game.zh?.name || game.en.name) : game.en.name
const getGameDesc = () => lang === 'zh-CN' || lang === 'zh-TW' ? (game.zh?.desc || game.en.desc) : game.en.desc

// Feedback i18n data
const f = t.feedback
---

<BaseLayout
  title={`${game.en.name} - RuleWord | Free Online Game`}
  description={`${game.en.desc} ${game.zh?.desc || ''}. Play ${game.en.name} free online at RuleWord.`}
  keywords={keywords}
  canonicalPath={`/games/${game.slug}/`}
  gameType={gameType}
>
  <div class="min-h-screen bg-slate-950 text-white flex flex-col">
    <!-- Navigation Bar -->
    <nav class="sticky top-0 z-50 bg-slate-950/90 border-b border-slate-800 backdrop-blur-xl">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="flex items-center justify-between h-14">
          <!-- Left: Logo -->
          <div class="flex items-center gap-4">
            <a href={`/?lang=${lang}`} class="flex items-center gap-2 hover:opacity-80 transition-opacity">
              <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-green-400 to-emerald-600 flex items-center justify-center text-white font-bold text-sm shadow-lg">
                R
              </div>
              <span class="font-semibold hidden sm:inline">RuleWord</span>
            </a>
          </div>

          <!-- Center: Game Title -->
          <h1 class="text-lg font-bold truncate max-w-[200px] sm:max-w-none">
            {game.icon} {getGameName()}
          </h1>

          <!-- Right: Language and Feedback -->
          <div class="flex items-center gap-2">
            <div class="relative">
              <button id="lang-btn" class="flex items-center gap-2 px-3 py-2 rounded-lg bg-slate-800 hover:bg-slate-700 transition-colors text-sm">
                <span class="text-lg">🌐</span>
                <span class="hidden sm:inline" id="current-lang">{languages.find(l => l.code === lang)?.nativeName || 'English'}</span>
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div id="lang-dropdown" class="absolute right-0 mt-2 w-48 bg-slate-800 rounded-lg shadow-xl z-20 py-1 border border-slate-700 hidden">
                {languages.map(l => (
                  <button data-lang={l.code} class="w-full px-4 py-2 text-left text-sm hover:bg-slate-700 text-slate-300">
                    {l.nativeName}
                  </button>
                ))}
              </div>
            </div>
            <button
              id="feedback-btn"
              class="flex items-center gap-1 px-3 py-1.5 rounded-lg bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-500 hover:to-pink-500 transition-all text-sm font-medium"
            >
              <span>💬</span>
              <span class="hidden sm:inline">{t.nav.feedback}</span>
            </button>
          </div>
        </div>
      </div>
    </nav>

    <!-- Game Area -->
    <main class="flex-1">
      <GameWrapper
        client:load
        gameId={game.id}
        gameName={game.en.name}
        gameSlug={game.slug}
      />
    </main>

    <!-- SEO Game Guide Section -->
    {gameGuideEn && (
      <section class="bg-slate-900/50 border-t border-slate-800 py-12 px-4 sm:px-6">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-2xl font-bold mb-4" id="guide-title">{getGameName()}: <span data-i18n="howToPlay">{t.game.howToPlay}</span></h2>

          <div class="prose prose-invert max-w-none">
            <p class="text-slate-300 text-lg mb-6" id="guide-intro" data-intro-en={gameGuideEn.intro} data-intro-zh={gameGuideZhCN?.intro || gameGuideEn.intro}>{gameGuideEn.intro}</p>

            <h3 class="text-xl font-semibold text-white mt-8 mb-4" data-i18n="howToPlay">{t.game.howToPlay}</h3>
            <p class="text-slate-300 mb-6" id="guide-howtoplay" data-howtoplay-en={gameGuideEn.howToPlay} data-howtoplay-zh={gameGuideZhCN?.howToPlay || gameGuideEn.howToPlay}>{gameGuideEn.howToPlay}</p>

            <h3 class="text-xl font-semibold text-white mt-8 mb-4" data-i18n="tips">{t.game.tips}</h3>
            <ul class="space-y-3" id="guide-tips">
              {gameGuideEn.tips.map((tip, i) => (
                <li class="flex items-start gap-3 text-slate-300" data-tip-en={tip} data-tip-zh={(gameGuideZhCN?.tips || gameGuideEn.tips)[i]}>
                  <span class="text-green-400 mt-1">•</span>
                  <span>{tip}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Related Games -->
          <div class="mt-12 pt-8 border-t border-slate-800">
            <h3 class="text-lg font-semibold mb-4" data-i18n="allGames">{t.home.allGames}</h3>
            <div class="flex flex-wrap gap-2" id="related-games">
              {gamesList.filter(g => g.category === game.category && g.id !== game.id).slice(0, 4).map(g => (
                <a
                  href={`/games/${g.slug}/`}
                  class="px-4 py-2 rounded-lg bg-slate-800 hover:bg-slate-700 transition-colors text-sm flex items-center gap-2 related-game"
                  data-name-en={g.en.name} data-name-zh={g.zh?.name || g.en.name}
                >
                  <span>{g.icon}</span>
                  <span class="game-name">{g.en.name}</span>
                </a>
              ))}
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- Footer -->
    <footer class="bg-slate-950 border-t border-slate-800 py-4 px-4 sm:px-6">
      <div class="max-w-7xl mx-auto flex items-center justify-between text-sm text-slate-400">
        <span>{t.home.copyright} · {getGameName()}</span>
        <span>{gamesList.length}+ {t.home.freeGames}</span>
      </div>
    </footer>
  </div>

  <!-- Feedback Modal (Localized) -->
  <div id="feedback-modal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" onclick="document.getElementById('feedback-modal').classList.add('hidden')"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-md bg-slate-800 rounded-2xl p-6 shadow-2xl">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-bold">💬 {f.title}</h3>
        <button onclick="document.getElementById('feedback-modal').classList.add('hidden')" class="text-slate-400 hover:text-white">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <form id="feedback-form" class="space-y-4">
        <div>
          <label class="block text-sm text-slate-300 mb-1">{f.type}</label>
          <select id="feedback-type" class="w-full px-3 py-2 rounded-lg bg-slate-700 border border-slate-600 text-white">
            <option value="bug">🐛 {f.bugReport}</option>
            <option value="feature">💡 {f.featureRequest}</option>
            <option value="game">🎮 {f.gameFeedback}</option>
            <option value="other">📝 {f.other}</option>
          </select>
        </div>
        <div>
          <label class="block text-sm text-slate-300 mb-1">{f.message}</label>
          <textarea id="feedback-message" rows="4" class="w-full px-3 py-2 rounded-lg bg-slate-700 border border-slate-600 text-white placeholder-slate-400" placeholder={f.messagePlaceholder}></textarea>
        </div>
        <div>
          <label class="block text-sm text-slate-300 mb-1">{f.email}</label>
          <input type="email" id="feedback-email" class="w-full px-3 py-2 rounded-lg bg-slate-700 border border-slate-600 text-white placeholder-slate-400" placeholder={f.emailPlaceholder} />
        </div>
        <input type="hidden" id="feedback-game" value={game.en.name} />
        <button type="submit" class="w-full py-2 rounded-lg bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-500 hover:to-pink-500 font-medium transition-all">
          {f.send}
        </button>
      </form>
      <div id="feedback-success" class="hidden text-center py-8">
        <div class="text-4xl mb-2">✅</div>
        <p class="text-green-400 font-medium">{f.success}</p>
      </div>
    </div>
  </div>

  <script define:vars={{ languages: languages, currentLang: lang, feedbackText: t.feedback, i18nData: i18n }}>
    // Language detection - check localStorage if URL param missing
    const validLangs = languages.map(l => l.code);
    const translations = i18nData;

    function getCurrentLang() {
      const params = new URLSearchParams(window.location.search);
      const urlLang = params.get('lang');
      if (urlLang && validLangs.includes(urlLang)) {
        localStorage.setItem('ruleword-lang', urlLang);
        return urlLang;
      }
      const stored = localStorage.getItem('ruleword-lang');
      if (stored && validLangs.includes(stored)) {
        return stored;
      }
      // Check browser language
      const browserLang = navigator.language || navigator.userLanguage;
      if (browserLang) {
        if (browserLang.startsWith('zh-CN') || browserLang === 'zh-Hans') return 'zh-CN';
        if (browserLang.startsWith('zh-TW') || browserLang === 'zh-Hant' || browserLang.startsWith('zh-HK')) return 'zh-TW';
        if (browserLang.startsWith('zh')) return 'zh-CN';
        if (browserLang.startsWith('fr')) return 'fr';
        if (browserLang.startsWith('de')) return 'de';
        if (browserLang.startsWith('es')) return 'es';
        if (browserLang.startsWith('ru')) return 'ru';
        if (browserLang.startsWith('ja')) return 'ja';
      }
      return 'en';
    }

    // Update game guide content based on language
    function updateGuideContent(lang) {
      const isZh = lang === 'zh-CN' || lang === 'zh-TW';

      // Update intro
      const introEl = document.getElementById('guide-intro');
      if (introEl) {
        introEl.textContent = isZh ? introEl.getAttribute('data-intro-zh') : introEl.getAttribute('data-intro-en');
      }

      // Update how to play
      const howToPlayEl = document.getElementById('guide-howtoplay');
      if (howToPlayEl) {
        howToPlayEl.textContent = isZh ? howToPlayEl.getAttribute('data-howtoplay-zh') : howToPlayEl.getAttribute('data-howtoplay-en');
      }

      // Update tips
      document.querySelectorAll('#guide-tips li').forEach(li => {
        const span = li.querySelector('span:last-child');
        if (span) {
          span.textContent = isZh ? li.getAttribute('data-tip-zh') : li.getAttribute('data-tip-en');
        }
      });

      // Update related game names
      document.querySelectorAll('.related-game').forEach(a => {
        const nameSpan = a.querySelector('.game-name');
        if (nameSpan) {
          nameSpan.textContent = isZh ? a.getAttribute('data-name-zh') : a.getAttribute('data-name-en');
        }
        // Update href with lang param
        const href = a.getAttribute('href');
        if (href) {
          const url = new URL(href, window.location.origin);
          url.searchParams.set('lang', lang);
          a.setAttribute('href', url.pathname + url.search);
        }
      });

      // Update UI text (howToPlay, tips, etc.)
      const t = translations[lang] || translations['en'];
      document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.getAttribute('data-i18n');
        if (t.game && t.game[key]) {
          el.textContent = t.game[key];
        } else if (t.home && t.home[key]) {
          el.textContent = t.home[key];
        }
      });
    }

    // Apply language on load
    const initialLang = getCurrentLang();
    if (initialLang !== 'en') {
      updateGuideContent(initialLang);
      // Update current lang button text
      const langObj = languages.find(l => l.code === initialLang);
      if (langObj) {
        document.getElementById('current-lang').textContent = langObj.nativeName;
      }
    }

    // Language dropdown
    const langBtn = document.getElementById('lang-btn');
    const langDropdown = document.getElementById('lang-dropdown');

    langBtn?.addEventListener('click', () => {
      langDropdown?.classList.toggle('hidden');
    });

    document.addEventListener('click', (e) => {
      if (!e.target.closest('#lang-btn') && !e.target.closest('#lang-dropdown')) {
        langDropdown?.classList.add('hidden');
      }
    });

    // Language selection - update content without page reload
    document.querySelectorAll('[data-lang]').forEach(btn => {
      btn.addEventListener('click', () => {
        const newLang = btn.getAttribute('data-lang');
        if (newLang) {
          localStorage.setItem('ruleword-lang', newLang);

          // Update URL without reload
          const url = new URL(window.location.href);
          url.searchParams.set('lang', newLang);
          window.history.pushState({}, '', url.toString());

          // Update content dynamically
          updateGuideContent(newLang);

          // Update current lang button text
          const langObj = languages.find(l => l.code === newLang);
          if (langObj) {
            document.getElementById('current-lang').textContent = langObj.nativeName;
          }

          // Close dropdown
          langDropdown?.classList.add('hidden');
        }
      });
    });

    // Feedback modal
    document.getElementById('feedback-btn')?.addEventListener('click', () => {
      document.getElementById('feedback-modal')?.classList.remove('hidden')
    })

    document.getElementById('feedback-form')?.addEventListener('submit', async (e) => {
      e.preventDefault()
      const form = e.target
      const submitBtn = form.querySelector('button[type="submit"]')

      submitBtn.disabled = true
      submitBtn.textContent = feedbackText.sending

      const data = {
        type: document.getElementById('feedback-type').value,
        message: document.getElementById('feedback-message').value,
        email: document.getElementById('feedback-email').value,
        game: document.getElementById('feedback-game').value,
      }

      try {
        const response = await fetch('https://api.emailjs.com/api/v1.0/email/send', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            service_id: 'service_2v1599e',
            template_id: 'template_9ee29rl',
            user_id: 'A73GlvN7cp09bDjon',
            template_params: {
              from_email: data.email || 'anonymous@ruleword.com',
              from_name: 'RuleWord User',
              message: `Type: ${data.type}\nGame: ${data.game}\n\n${data.message}`,
            }
          })
        })

        if (response.ok) {
          form.classList.add('hidden')
          document.getElementById('feedback-success')?.classList.remove('hidden')
        } else {
          throw new Error('Failed to send')
        }
      } catch (err) {
        submitBtn.disabled = false
        submitBtn.textContent = feedbackText.send
        alert(feedbackText.fail)
      }
    })
  </script>
</BaseLayout>
