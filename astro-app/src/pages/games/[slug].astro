---
import BaseLayout from '../../layouts/BaseLayout.astro'
import GameWrapper from '../../components/GameWrapper'
import { getCollection, type CollectionEntry } from 'astro:content'
import { getAllGames, getAllGameSlugs, getGameBySlug, type GameData as CMSGameData } from '../../lib/games'
import { categories } from '../../data/games'
import { i18n, categoryI18n, type Language, languages } from '../../data/i18n'

// 在 getStaticPaths 中获取所有游戏
export async function getStaticPaths() {
  // 数据源选择：优先使用 CMS（Sanity），回退到本地 JSON
  const useCMS = !!import.meta.env.SANITY_PROJECT_ID

  const slugs = await getAllGameSlugs()
  const allCMSGames = useCMS ? await getAllGames() : null

  // 如果使用 CMS，从 CMS 获取数据
  if (useCMS && allCMSGames) {
    return slugs.map(slug => ({
      params: { slug },
      props: {
        game: allCMSGames.find(g => g.slug === slug),
        allGames: allCMSGames,
        useCMS: true
      }
    }))
  }

  // 回退到本地 JSON
  const gamesCollection = await getCollection('games')
  const allGames = gamesCollection.map(entry => entry.data)

  return gamesCollection.map(entry => ({
    params: { slug: entry.data.slug },
    props: { game: entry.data, allGames, useCMS: false }
  }))
}

// 兼容本地 JSON 格式
interface GameRules {
  controls?: string
  mechanics?: string[]
  features?: string[]
}

interface GameFAQ {
  question: string
  answer: string
}

interface LocalGameData {
  id: string
  slug: string
  icon: string
  category: 'word' | 'logic' | 'strategy' | 'arcade' | 'memory' | 'skill' | 'puzzle'
  featured?: boolean
  color: string
  en: {
    name: string
    desc: string
    description?: string
    objectives?: string
    howToPlay?: string
    rules?: GameRules
    tips?: string[]
    faq?: GameFAQ[]
  }
  zh?: {
    name: string
    desc: string
    description?: string
    objectives?: string
    howToPlay?: string
    rules?: GameRules
    tips?: string[]
    faq?: GameFAQ[]
  }
}

type GameData = LocalGameData | CMSGameData

const { game, allGames: gamesList, useCMS } = Astro.props as {
  game: GameData
  allGames: GameData[]
  useCMS: boolean
}

// Get language from URL parameter, default to 'en'
const urlLang = Astro.url.searchParams.get('lang') as string
const lang: Language = languages.some(l => l.code === urlLang) ? (urlLang as Language) : 'en'
const t = i18n[lang]

// Helper to get game field (兼容 CMS 和本地格式)
const getGameField = (field: 'name' | 'desc' | 'description' | 'objectives' | 'howToPlay' | 'tips' | 'rules' | 'faq', preferLang: 'en' | 'zh' = 'en'): string | string[] | GameRules | GameFAQ[] => {
  if (useCMS) {
    const cmsGame = game as CMSGameData
    if (field === 'name') return preferLang === 'zh' ? (cmsGame.nameZh || cmsGame.name) : cmsGame.name
    if (field === 'desc') return preferLang === 'zh' ? (cmsGame.descZh || cmsGame.desc) : cmsGame.desc
    if (field === 'description') return preferLang === 'zh' ? (cmsGame.descZh || cmsGame.desc) : cmsGame.desc
    if (field === 'objectives') return ''
    if (field === 'howToPlay') return preferLang === 'zh' ? (cmsGame.howToPlayZh || cmsGame.howToPlay || '') : (cmsGame.howToPlay || '')
    if (field === 'tips') return preferLang === 'zh' ? (cmsGame.tipsZh || cmsGame.tips || []) : (cmsGame.tips || [])
    if (field === 'rules') return {}
    if (field === 'faq') return []
  }
  const localGame = game as LocalGameData
  const enData = localGame.en || {}
  const zhData = localGame.zh || {}

  if (field === 'name') return preferLang === 'zh' ? (zhData.name || enData.name) : enData.name
  if (field === 'desc') return preferLang === 'zh' ? (zhData.desc || enData.desc) : enData.desc
  if (field === 'description') {
    const zhDesc = zhData.description || zhData.desc || ''
    const enDesc = enData.description || enData.desc || ''
    return preferLang === 'zh' ? (zhDesc || enDesc) : enDesc
  }
  if (field === 'objectives') {
    const zhObj = zhData.objectives || ''
    const enObj = enData.objectives || ''
    return preferLang === 'zh' ? (zhObj || enObj) : enObj
  }
  if (field === 'howToPlay') return preferLang === 'zh' ? (zhData.howToPlay || enData.howToPlay || '') : (enData.howToPlay || '')
  if (field === 'tips') return preferLang === 'zh' ? (zhData.tips || enData.tips || []) : (enData.tips || [])
  if (field === 'rules') return preferLang === 'zh' ? (zhData.rules || enData.rules || {}) : (enData.rules || {})
  if (field === 'faq') return preferLang === 'zh' ? (zhData.faq || enData.faq || []) : (enData.faq || [])
  return ''
}

// Get game guide content
const gameGuideEn = {
  intro: getGameField('desc', 'en') as string,
  description: getGameField('description', 'en') as string,
  objectives: getGameField('objectives', 'en') as string,
  howToPlay: getGameField('howToPlay', 'en') as string,
  rules: getGameField('rules', 'en') as GameRules,
  tips: getGameField('tips', 'en') as string[],
  faq: getGameField('faq', 'en') as GameFAQ[]
}
const gameGuideZhCN = {
  intro: getGameField('desc', 'zh') as string,
  description: getGameField('description', 'zh') as string,
  objectives: getGameField('objectives', 'zh') as string,
  howToPlay: getGameField('howToPlay', 'zh') as string,
  rules: getGameField('rules', 'zh') as GameRules,
  tips: getGameField('tips', 'zh') as string[],
  faq: getGameField('faq', 'zh') as GameFAQ[]
}

// For SEO, use English as default
const gameGuide = gameGuideEn

// Get category for gameType with i18n
const category = categories.find(c => c.id === game.category)
const categoryData = categoryI18n[lang]?.[game.category]
const gameType = categoryData?.name || category?.name || 'Puzzle'

// Build keywords from game info
const keywords = `${getGameField('name', 'en')}, ${getGameField('name', 'zh')}, ${getGameField('desc', 'en')}, ${getGameField('desc', 'zh')}, free online game, puzzle game`

// Helper for localized game name
const getGameName = () => getGameField('name', lang === 'zh-CN' || lang === 'zh-TW' ? 'zh' : 'en') as string
const getGameDesc = () => getGameField('desc', lang === 'zh-CN' || lang === 'zh-TW' ? 'zh' : 'en') as string

// Get game ID (compatible with both formats)
const gameId = useCMS ? (game as CMSGameData).id : (game as LocalGameData).id
const gameSlug = game.slug
const gameIcon = game.icon

// Check if external game
const isExternalGame = useCMS && (game as CMSGameData).isExternal
const externalGameData = isExternalGame ? (game as CMSGameData) : null

// Feedback i18n data
const f = t.feedback
---

<BaseLayout
  title={`${getGameField('name', 'en')} - RuleWord | Free Online Game`}
  description={`${getGameField('desc', 'en')} ${getGameField('desc', 'zh')}. Play ${getGameField('name', 'en')} free online at RuleWord.`}
  keywords={keywords}
  canonicalPath={`/games/${game.slug}/`}
  gameType={gameType}
>
  <!-- Prefetch homepage for faster navigation -->
  <link rel="prefetch" href="/" />
  <div class="min-h-screen bg-slate-950 text-white flex flex-col">
    <!-- Navigation Bar -->
    <nav class="sticky top-0 z-50 bg-slate-950/90 border-b border-slate-800 backdrop-blur-xl">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="flex items-center justify-between h-14">
          <!-- Left: Logo -->
          <div class="flex items-center gap-4">
            <a href={`/?lang=${lang}`} class="flex items-center gap-2 hover:opacity-80 transition-opacity">
              <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-green-400 to-emerald-600 flex items-center justify-center text-white font-bold text-sm shadow-lg">
                R
              </div>
              <span class="font-semibold hidden sm:inline">RuleWord</span>
            </a>
          </div>

          <!-- Center: Game Title -->
          <h1 class="text-lg font-bold truncate max-w-[200px] sm:max-w-none">
            {gameIcon} {getGameName()}
          </h1>

          <!-- Right: Language and Feedback -->
          <div class="flex items-center gap-2">
            <div class="relative">
              <button id="lang-btn" class="flex items-center gap-2 px-3 py-2 rounded-lg bg-slate-800 hover:bg-slate-700 transition-colors text-sm">
                <span class="text-lg">🌐</span>
                <span class="hidden sm:inline" id="current-lang">{languages.find(l => l.code === lang)?.nativeName || 'English'}</span>
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div id="lang-dropdown" class="absolute right-0 mt-2 w-48 bg-slate-800 rounded-lg shadow-xl z-20 py-1 border border-slate-700 hidden">
                {languages.map(l => (
                  <button data-lang={l.code} class="w-full px-4 py-2 text-left text-sm hover:bg-slate-700 text-slate-300">
                    {l.nativeName}
                  </button>
                ))}
              </div>
            </div>
            <button
              id="feedback-btn"
              class="flex items-center gap-1 px-3 py-1.5 rounded-lg bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-500 hover:to-pink-500 transition-all text-sm font-medium"
            >
              <span>💬</span>
              <span class="hidden sm:inline">{t.nav.feedback}</span>
            </button>
          </div>
        </div>
      </div>
    </nav>

    <!-- Game Area -->
    <main class="flex-1">
      {isExternalGame && externalGameData?.gameUrl ? (
        <!-- External Game iframe -->
        <div class="w-full h-full flex flex-col">
          <iframe
            src={externalGameData.gameUrl}
            width={externalGameData.iframeWidth || '100%'}
            height={externalGameData.iframeHeight || '600px'}
            allowfullscreen={externalGameData.allowFullscreen ?? true}
            class="flex-1 min-h-[600px] border-0"
            title={getGameName()}
            loading="lazy"
          ></iframe>
          {externalGameData.sourceName && (
            <div class="text-center py-2 text-sm text-slate-400 bg-slate-900/50">
              {t.game.source || 'Source'}: {externalGameData.sourceUrl ? (
                <a href={externalGameData.sourceUrl} target="_blank" rel="noopener noreferrer" class="text-blue-400 hover:underline">
                  {externalGameData.sourceName}
                </a>
              ) : externalGameData.sourceName}
            </div>
          )}
        </div>
      ) : (
        <!-- Built-in Game -->
        <GameWrapper
          client:visible
          gameId={gameId}
          gameName={getGameField('name', 'en') as string}
          gameSlug={gameSlug}
        />
      )}
    </main>

    <!-- SEO Game Guide Section -->
    {gameGuideEn && (
      <section class="bg-slate-900/50 border-t border-slate-800 py-12 px-4 sm:px-6">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-2xl font-bold mb-6" id="guide-title">{getGameName()} <span class="text-slate-400 font-normal" data-i18n="gameGuide">Game Guide</span></h2>

          <div class="prose prose-invert max-w-none space-y-8">
            <!-- Game Description -->
            <div id="guide-description-section">
              <h3 class="text-xl font-semibold text-white mb-4 flex items-center gap-2">
                <span class="text-2xl">📖</span>
                <span data-i18n="about">{t.game.about || 'About'}</span>
              </h3>
              <p class="text-slate-300 text-lg leading-relaxed" id="guide-description" data-description-en={gameGuideEn.description || gameGuideEn.intro} data-description-zh={gameGuideZhCN?.description || gameGuideZhCN?.intro || gameGuideEn.description || gameGuideEn.intro}>
                {gameGuideEn.description || gameGuideEn.intro}
              </p>
            </div>

            <!-- Game Objectives -->
            {gameGuideEn.objectives && (
              <div id="guide-objectives-section">
                <h3 class="text-xl font-semibold text-white mb-4 flex items-center gap-2">
                  <span class="text-2xl">🎯</span>
                  <span data-i18n="objectives">{t.game.objectives || 'Objectives'}</span>
                </h3>
                <p class="text-slate-300 leading-relaxed" id="guide-objectives" data-objectives-en={gameGuideEn.objectives} data-objectives-zh={gameGuideZhCN?.objectives || gameGuideEn.objectives}>
                  {gameGuideEn.objectives}
                </p>
              </div>
            )}

            <!-- How to Play -->
            <div id="guide-howtoplay-section">
              <h3 class="text-xl font-semibold text-white mb-4 flex items-center gap-2">
                <span class="text-2xl">🎮</span>
                <span data-i18n="howToPlay">{t.game.howToPlay}</span>
              </h3>
              <p class="text-slate-300 mb-4" id="guide-howtoplay" data-howtoplay-en={gameGuideEn.howToPlay} data-howtoplay-zh={gameGuideZhCN?.howToPlay || gameGuideEn.howToPlay}>
                {gameGuideEn.howToPlay}
              </p>

              <!-- Game Rules -->
              {gameGuideEn.rules && (gameGuideEn.rules.controls || gameGuideEn.rules.mechanics?.length || gameGuideEn.rules.features?.length) && (
                <div class="mt-6 space-y-4 bg-slate-800/50 rounded-xl p-6">
                  {gameGuideEn.rules.controls && (
                    <div>
                      <h4 class="text-lg font-medium text-white mb-2 flex items-center gap-2">
                        <span>⌨️</span>
                        <span data-i18n="controls">{t.game.controls || 'Controls'}</span>
                      </h4>
                      <p class="text-slate-300" id="guide-controls" data-controls-en={gameGuideEn.rules.controls} data-controls-zh={gameGuideZhCN?.rules?.controls || gameGuideEn.rules.controls}>
                        {gameGuideEn.rules.controls}
                      </p>
                    </div>
                  )}

                  {gameGuideEn.rules.mechanics && gameGuideEn.rules.mechanics.length > 0 && (
                    <div>
                      <h4 class="text-lg font-medium text-white mb-2 flex items-center gap-2">
                        <span>⚙️</span>
                        <span data-i18n="mechanics">{t.game.mechanics || 'Game Mechanics'}</span>
                      </h4>
                      <ul class="space-y-2" id="guide-mechanics">
                        {gameGuideEn.rules.mechanics.map((mechanic, i) => (
                          <li class="flex items-start gap-3 text-slate-300" data-mechanic-en={mechanic} data-mechanic-zh={gameGuideZhCN?.rules?.mechanics?.[i] || mechanic}>
                            <span class="text-blue-400 mt-1">▸</span>
                            <span>{mechanic}</span>
                          </li>
                        ))}
                      </ul>
                    </div>
                  )}

                  {gameGuideEn.rules.features && gameGuideEn.rules.features.length > 0 && (
                    <div>
                      <h4 class="text-lg font-medium text-white mb-2 flex items-center gap-2">
                        <span>✨</span>
                        <span data-i18n="features">{t.game.features || 'Features'}</span>
                      </h4>
                      <ul class="space-y-2" id="guide-features">
                        {gameGuideEn.rules.features.map((feature, i) => (
                          <li class="flex items-start gap-3 text-slate-300" data-feature-en={feature} data-feature-zh={gameGuideZhCN?.rules?.features?.[i] || feature}>
                            <span class="text-yellow-400 mt-1">★</span>
                            <span>{feature}</span>
                          </li>
                        ))}
                      </ul>
                    </div>
                  )}
                </div>
              )}
            </div>

            <!-- Tips -->
            {gameGuideEn.tips && gameGuideEn.tips.length > 0 && (
              <div id="guide-tips-section">
                <h3 class="text-xl font-semibold text-white mb-4 flex items-center gap-2">
                  <span class="text-2xl">💡</span>
                  <span data-i18n="tips">{t.game.tips}</span>
                </h3>
                <ul class="space-y-3" id="guide-tips">
                  {gameGuideEn.tips.map((tip, i) => (
                    <li class="flex items-start gap-3 text-slate-300 bg-slate-800/30 rounded-lg p-3" data-tip-en={tip} data-tip-zh={(gameGuideZhCN?.tips || gameGuideEn.tips)[i]}>
                      <span class="text-green-400 mt-1">✓</span>
                      <span>{tip}</span>
                    </li>
                  ))}
                </ul>
              </div>
            )}

            <!-- FAQ Section -->
            {gameGuideEn.faq && gameGuideEn.faq.length > 0 && (
              <div id="guide-faq-section">
                <h3 class="text-xl font-semibold text-white mb-4 flex items-center gap-2">
                  <span class="text-2xl">❓</span>
                  <span data-i18n="faq">{t.game.faq || 'Frequently Asked Questions'}</span>
                </h3>
                <div class="space-y-4" id="guide-faq">
                  {gameGuideEn.faq.map((item, i) => (
                    <details class="group bg-slate-800/50 rounded-xl overflow-hidden">
                      <summary class="flex items-center justify-between p-4 cursor-pointer hover:bg-slate-800/70 transition-colors">
                        <span class="font-medium text-white" data-question-en={item.question} data-question-zh={gameGuideZhCN?.faq?.[i]?.question || item.question}>
                          {item.question}
                        </span>
                        <svg class="w-5 h-5 text-slate-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                        </svg>
                      </summary>
                      <div class="px-4 pb-4 text-slate-300" data-answer-en={item.answer} data-answer-zh={gameGuideZhCN?.faq?.[i]?.answer || item.answer}>
                        {item.answer}
                      </div>
                    </details>
                  ))}
                </div>
              </div>
            )}
          </div>

          <!-- Related Games -->
          <div class="mt-12 pt-8 border-t border-slate-800">
            <h3 class="text-lg font-semibold mb-4" data-i18n="allGames">{t.home.allGames}</h3>
            <div class="flex flex-wrap gap-2" id="related-games">
              {gamesList.filter(g => g.category === game.category && g.slug !== gameSlug).slice(0, 4).map(g => {
                const gId = useCMS ? (g as CMSGameData).id : (g as LocalGameData).id
                const gNameEn = useCMS ? (g as CMSGameData).name : (g as LocalGameData).en.name
                const gNameZh = useCMS ? (g as CMSGameData).nameZh || (g as CMSGameData).name : ((g as LocalGameData).zh?.name || (g as LocalGameData).en.name)
                return (
                <a
                  href={`/games/${g.slug}/`}
                  class="px-4 py-2 rounded-lg bg-slate-800 hover:bg-slate-700 transition-colors text-sm flex items-center gap-2 related-game"
                  data-name-en={gNameEn} data-name-zh={gNameZh}
                >
                  <span>{g.icon}</span>
                  <span class="game-name">{gNameEn}</span>
                </a>
              )})}
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- Footer -->
    <footer class="bg-slate-950 border-t border-slate-800 py-4 px-4 sm:px-6">
      <div class="max-w-7xl mx-auto flex items-center justify-between text-sm text-slate-400">
        <span>{t.home.copyright} · {getGameName()}</span>
        <span>{gamesList.length}+ {t.home.freeGames}</span>
      </div>
    </footer>
  </div>

  <!-- Feedback Modal (Localized) -->
  <div id="feedback-modal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" onclick="document.getElementById('feedback-modal').classList.add('hidden')"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-md bg-slate-800 rounded-2xl p-6 shadow-2xl">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-bold">💬 {f.title}</h3>
        <button onclick="document.getElementById('feedback-modal').classList.add('hidden')" class="text-slate-400 hover:text-white">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <form id="feedback-form" class="space-y-4">
        <div>
          <label class="block text-sm text-slate-300 mb-1">{f.type}</label>
          <select id="feedback-type" class="w-full px-3 py-2 rounded-lg bg-slate-700 border border-slate-600 text-white">
            <option value="bug">🐛 {f.bugReport}</option>
            <option value="feature">💡 {f.featureRequest}</option>
            <option value="game">🎮 {f.gameFeedback}</option>
            <option value="other">📝 {f.other}</option>
          </select>
        </div>
        <div>
          <label class="block text-sm text-slate-300 mb-1">{f.message}</label>
          <textarea id="feedback-message" rows="4" class="w-full px-3 py-2 rounded-lg bg-slate-700 border border-slate-600 text-white placeholder-slate-400" placeholder={f.messagePlaceholder}></textarea>
        </div>
        <div>
          <label class="block text-sm text-slate-300 mb-1">{f.email}</label>
          <input type="email" id="feedback-email" class="w-full px-3 py-2 rounded-lg bg-slate-700 border border-slate-600 text-white placeholder-slate-400" placeholder={f.emailPlaceholder} />
        </div>
        <input type="hidden" id="feedback-game" value={getGameField('name', 'en')} />
        <button type="submit" class="w-full py-2 rounded-lg bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-500 hover:to-pink-500 font-medium transition-all">
          {f.send}
        </button>
      </form>
      <div id="feedback-success" class="hidden text-center py-8">
        <div class="text-4xl mb-2">✅</div>
        <p class="text-green-400 font-medium">{f.success}</p>
      </div>
    </div>
  </div>

  <script define:vars={{ languages: languages, currentLang: lang, feedbackText: t.feedback, i18nData: i18n }}>
    // Language detection - check localStorage if URL param missing
    const validLangs = languages.map(l => l.code);
    const translations = i18nData;

    function getCurrentLang() {
      const params = new URLSearchParams(window.location.search);
      const urlLang = params.get('lang');
      if (urlLang && validLangs.includes(urlLang)) {
        localStorage.setItem('ruleword-lang', urlLang);
        return urlLang;
      }
      const stored = localStorage.getItem('ruleword-lang');
      if (stored && validLangs.includes(stored)) {
        return stored;
      }
      // Check browser language
      const browserLang = navigator.language || navigator.userLanguage;
      if (browserLang) {
        if (browserLang.startsWith('zh-CN') || browserLang === 'zh-Hans') return 'zh-CN';
        if (browserLang.startsWith('zh-TW') || browserLang === 'zh-Hant' || browserLang.startsWith('zh-HK')) return 'zh-TW';
        if (browserLang.startsWith('zh')) return 'zh-CN';
        if (browserLang.startsWith('fr')) return 'fr';
        if (browserLang.startsWith('de')) return 'de';
        if (browserLang.startsWith('es')) return 'es';
        if (browserLang.startsWith('ru')) return 'ru';
        if (browserLang.startsWith('ja')) return 'ja';
      }
      return 'en';
    }

    // Update game guide content based on language
    function updateGuideContent(lang) {
      const isZh = lang === 'zh-CN' || lang === 'zh-TW';

      // Update description
      const descEl = document.getElementById('guide-description');
      if (descEl) {
        descEl.textContent = isZh ? descEl.getAttribute('data-description-zh') : descEl.getAttribute('data-description-en');
      }

      // Update objectives
      const objectivesEl = document.getElementById('guide-objectives');
      if (objectivesEl) {
        objectivesEl.textContent = isZh ? objectivesEl.getAttribute('data-objectives-zh') : objectivesEl.getAttribute('data-objectives-en');
      }

      // Update how to play
      const howToPlayEl = document.getElementById('guide-howtoplay');
      if (howToPlayEl) {
        howToPlayEl.textContent = isZh ? howToPlayEl.getAttribute('data-howtoplay-zh') : howToPlayEl.getAttribute('data-howtoplay-en');
      }

      // Update controls
      const controlsEl = document.getElementById('guide-controls');
      if (controlsEl) {
        controlsEl.textContent = isZh ? controlsEl.getAttribute('data-controls-zh') : controlsEl.getAttribute('data-controls-en');
      }

      // Update mechanics
      document.querySelectorAll('#guide-mechanics li').forEach(li => {
        const span = li.querySelector('span:last-child');
        if (span) {
          span.textContent = isZh ? li.getAttribute('data-mechanic-zh') : li.getAttribute('data-mechanic-en');
        }
      });

      // Update features
      document.querySelectorAll('#guide-features li').forEach(li => {
        const span = li.querySelector('span:last-child');
        if (span) {
          span.textContent = isZh ? li.getAttribute('data-feature-zh') : li.getAttribute('data-feature-en');
        }
      });

      // Update tips
      document.querySelectorAll('#guide-tips li').forEach(li => {
        const span = li.querySelector('span:last-child');
        if (span) {
          span.textContent = isZh ? li.getAttribute('data-tip-zh') : li.getAttribute('data-tip-en');
        }
      });

      // Update FAQ
      document.querySelectorAll('#guide-faq details').forEach(details => {
        const summary = details.querySelector('summary span');
        const answer = details.querySelector('div');
        if (summary) {
          summary.textContent = isZh ? summary.getAttribute('data-question-zh') : summary.getAttribute('data-question-en');
        }
        if (answer) {
          answer.textContent = isZh ? answer.getAttribute('data-answer-zh') : answer.getAttribute('data-answer-en');
        }
      });

      // Update related game names
      document.querySelectorAll('.related-game').forEach(a => {
        const nameSpan = a.querySelector('.game-name');
        if (nameSpan) {
          nameSpan.textContent = isZh ? a.getAttribute('data-name-zh') : a.getAttribute('data-name-en');
        }
        // Update href with lang param
        const href = a.getAttribute('href');
        if (href) {
          const url = new URL(href, window.location.origin);
          url.searchParams.set('lang', lang);
          a.setAttribute('href', url.pathname + url.search);
        }
      });

      // Update UI text (howToPlay, tips, etc.)
      const t = translations[lang] || translations['en'];
      document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.getAttribute('data-i18n');
        if (t.game && t.game[key]) {
          el.textContent = t.game[key];
        } else if (t.home && t.home[key]) {
          el.textContent = t.home[key];
        }
      });
    }

    // Apply language on load
    const initialLang = getCurrentLang();
    if (initialLang !== 'en') {
      updateGuideContent(initialLang);
      // Update current lang button text
      const langObj = languages.find(l => l.code === initialLang);
      if (langObj) {
        document.getElementById('current-lang').textContent = langObj.nativeName;
      }
    }

    // Language dropdown
    const langBtn = document.getElementById('lang-btn');
    const langDropdown = document.getElementById('lang-dropdown');

    langBtn?.addEventListener('click', () => {
      langDropdown?.classList.toggle('hidden');
    });

    document.addEventListener('click', (e) => {
      if (!e.target.closest('#lang-btn') && !e.target.closest('#lang-dropdown')) {
        langDropdown?.classList.add('hidden');
      }
    });

    // Language selection - update content without page reload
    document.querySelectorAll('[data-lang]').forEach(btn => {
      btn.addEventListener('click', () => {
        const newLang = btn.getAttribute('data-lang');
        if (newLang) {
          localStorage.setItem('ruleword-lang', newLang);

          // Update URL without reload
          const url = new URL(window.location.href);
          url.searchParams.set('lang', newLang);
          window.history.pushState({}, '', url.toString());

          // Update content dynamically
          updateGuideContent(newLang);

          // Update current lang button text
          const langObj = languages.find(l => l.code === newLang);
          if (langObj) {
            document.getElementById('current-lang').textContent = langObj.nativeName;
          }

          // Close dropdown
          langDropdown?.classList.add('hidden');
        }
      });
    });

    // Feedback modal
    document.getElementById('feedback-btn')?.addEventListener('click', () => {
      document.getElementById('feedback-modal')?.classList.remove('hidden')
    })

    document.getElementById('feedback-form')?.addEventListener('submit', async (e) => {
      e.preventDefault()
      const form = e.target
      const submitBtn = form.querySelector('button[type="submit"]')

      submitBtn.disabled = true
      submitBtn.textContent = feedbackText.sending

      const data = {
        type: document.getElementById('feedback-type').value,
        message: document.getElementById('feedback-message').value,
        email: document.getElementById('feedback-email').value,
        game: document.getElementById('feedback-game').value,
      }

      try {
        const response = await fetch('https://api.emailjs.com/api/v1.0/email/send', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            service_id: 'service_2v1599e',
            template_id: 'template_9ee29rl',
            user_id: 'A73GlvN7cp09bDjon',
            template_params: {
              from_email: data.email || 'anonymous@ruleword.com',
              from_name: 'RuleWord User',
              message: `Type: ${data.type}\nGame: ${data.game}\n\n${data.message}`,
            }
          })
        })

        if (response.ok) {
          form.classList.add('hidden')
          document.getElementById('feedback-success')?.classList.remove('hidden')
        } else {
          throw new Error('Failed to send')
        }
      } catch (err) {
        submitBtn.disabled = false
        submitBtn.textContent = feedbackText.send
        alert(feedbackText.fail)
      }
    })
  </script>
</BaseLayout>
