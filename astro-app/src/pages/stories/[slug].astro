---
import BaseLayout from '../../layouts/BaseLayout.astro'
import StoryGameWithShare from '../../components/ai/StoryGameWithShare'
import { getCollection } from 'astro:content'
import { languages, type Language } from '../../data/i18n'
import { getGameRating } from '../../data/gameRatings'

export async function getStaticPaths() {
  const stories = await getCollection('stories')
  const allStoriesData = stories.map(entry => ({
    slug: entry.data.slug,
    name: entry.data.en.name,
    desc: entry.data.en.desc,
    icon: entry.data.icon,
    color: entry.data.color,
    templateType: entry.data.templateType,
  }))
  return stories.map(entry => ({
    params: { slug: entry.data.slug },
    props: { story: entry.data, allStories: allStoriesData },
  }))
}

const { story, allStories } = Astro.props
const lang: Language = 'en'

// Get other stories for cross-linking
const otherStories = allStories.filter((s: any) => s.slug !== story.slug).slice(0, 4)

const storyName = story.en.name
const storyDesc = story.en.desc
const storyDescription = story.en.description
const storyHowToPlay = story.en.howToPlay
const templateType = story.templateType
const storyTips = story.en.tips || []
const storyFaq = story.en.faq || []
const storyIcon = story.icon
const characters = story.storySkeleton.characters
const chapters = story.storySkeleton.chapters

const seoTitle = `${storyName} - Play AI Interactive Story Game Online Free | Free Games Hub`
const seoDescription = storyDesc
const seoKeywords = `${storyName.toLowerCase()}, AI story game, interactive fiction, AI game, play online free, browser game, no download`

const breadcrumbItems = [
  { name: 'Home', url: '/' },
  { name: 'AI Stories', url: '/stories/' },
  { name: storyName, url: `/stories/${story.slug}/` },
]

const howToSchema = storyHowToPlay ? {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": `How to Play ${storyName}`,
  "description": storyDesc,
  "totalTime": "PT10M",
  "tool": { "@type": "HowToTool", "name": "Web Browser" },
  "step": [
    { "@type": "HowToStep", "text": "Click 'Start Story' to begin your AI interactive adventure" },
    { "@type": "HowToStep", "text": storyHowToPlay },
    { "@type": "HowToStep", "text": "Make choices to shape the story and your relationships" },
  ],
} : undefined

const storyRating = getGameRating(`ai-${story.slug.replace('ai-', '')}`)
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  keywords={seoKeywords}
  canonicalPath={`/stories/${story.slug}/`}
  ogImage={`/og/story-${story.slug}.png`}
  gameType="Interactive Fiction"
  breadcrumbItems={breadcrumbItems}
  howToSchema={howToSchema}
  aggregateRating={storyRating}
>
  <div class="min-h-screen bg-slate-950 text-white flex flex-col">
    <!-- Navigation Bar -->
    <nav class="sticky top-0 z-50 bg-slate-950/90 border-b border-slate-800 backdrop-blur-xl">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="flex items-center justify-between h-14">
          <div class="flex items-center gap-4">
            <a href="/" class="flex items-center gap-2 hover:opacity-80 transition-opacity">
              <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-green-400 to-emerald-600 flex items-center justify-center text-white font-bold text-sm shadow-lg">R</div>
              <span class="font-semibold hidden sm:inline">Free Games Hub</span>
            </a>
          </div>
          <h1 class="text-lg font-bold truncate max-w-[200px] sm:max-w-none">
            <span class="hidden sm:inline">Play {storyName} Online Free</span>
            <span class="sm:hidden">{storyIcon} {storyName}</span>
          </h1>
          <div class="flex items-center gap-2">
            <a href="/stories/" class="text-sm text-pink-400 hover:text-pink-300 transition-colors">All AI Stories</a>
          </div>
        </div>
      </div>
    </nav>

    <!-- Game Area - fixed viewport height (dvh for mobile browser compatibility) -->
    <main class="h-[calc(100dvh-3.5rem)] relative">
      <StoryGameWithShare
        client:load
        template={JSON.stringify(story)}
        gameName={storyName}
        gameSlug={story.slug}
        gameEmoji={storyIcon}
      />
    </main>

    <!-- SEO Content Section -->
    <section class="bg-slate-900/50 border-t border-slate-800 py-12 px-4 sm:px-6">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl font-bold mb-6">{storyName} — AI Interactive Story Game</h2>

        <div class="prose prose-invert max-w-none space-y-8">
          <!-- Description -->
          <div>
            <h3 class="text-xl font-semibold text-white mb-4 flex items-center gap-2">
              <span class="text-2xl">📖</span> About This Story
            </h3>
            <p class="text-slate-300 text-lg leading-relaxed">{storyDescription}</p>
          </div>

          <!-- Characters -->
          {characters.length > 0 && (
            <div>
              <h3 class="text-xl font-semibold text-white mb-4 flex items-center gap-2">
                <span class="text-2xl">🎭</span> Characters
              </h3>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                {characters.map(char => (
                  <div class="bg-slate-800/50 rounded-xl p-4 border border-slate-700/50">
                    <h4 class="text-white font-semibold mb-1">{char.name}</h4>
                    {char.relationship && <p class="text-pink-400 text-sm mb-2">{char.relationship}</p>}
                    <p class="text-slate-400 text-sm">{char.personality}</p>
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- Story Chapters -->
          <div>
            <h3 class="text-xl font-semibold text-white mb-4 flex items-center gap-2">
              <span class="text-2xl">📚</span> Story Chapters
            </h3>
            <div class="space-y-2">
              {chapters.map((chapter, i) => (
                <div class="flex items-center gap-3 text-slate-300">
                  <span class="text-pink-400 font-mono text-sm w-6">Ch.{i + 1}</span>
                  <span class="text-sm">{chapter.title || chapter.goal}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- How to Play -->
          {storyHowToPlay && (
            <div>
              <h3 class="text-xl font-semibold text-white mb-4 flex items-center gap-2">
                <span class="text-2xl">🎮</span> How to Play
              </h3>
              <p class="text-slate-300 leading-relaxed">{storyHowToPlay}</p>
            </div>
          )}

          <!-- Tips -->
          {storyTips.length > 0 && (
            <div>
              <h3 class="text-xl font-semibold text-white mb-4 flex items-center gap-2">
                <span class="text-2xl">💡</span> Tips
              </h3>
              <ul class="space-y-2">
                {storyTips.map(tip => (
                  <li class="flex gap-2 text-slate-300">
                    <span class="text-pink-400 shrink-0">•</span>
                    <span class="text-sm">{tip}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}

          <!-- FAQ -->
          {storyFaq.length > 0 && (
            <div>
              <h3 class="text-xl font-semibold text-white mb-4 flex items-center gap-2">
                <span class="text-2xl">❓</span> Frequently Asked Questions
              </h3>
              <div class="space-y-4">
                {storyFaq.map(item => (
                  <details class="group bg-slate-800/30 rounded-lg">
                    <summary class="px-4 py-3 cursor-pointer text-white font-medium hover:text-pink-400 transition-colors">
                      {item.question}
                    </summary>
                    <p class="px-4 pb-3 text-slate-400 text-sm">{item.answer}</p>
                  </details>
                ))}
              </div>
            </div>
          )}
        </div>
      </div>
    </section>

    <!-- Related Stories -->
    <section class="bg-slate-900/30 border-t border-slate-800 py-8 px-4 sm:px-6">
      <div class="max-w-4xl mx-auto">
        <h3 class="text-lg font-semibold mb-4 text-center">Explore More AI Stories</h3>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-4">
          {otherStories.map((s: any) => (
            <a href={`/stories/${s.slug}/`} class="group block bg-slate-800/60 rounded-xl overflow-hidden hover:bg-slate-700/60 transition-all border border-slate-700/50">
              <div class={`h-1 bg-gradient-to-r ${s.color}`} />
              <div class="p-3">
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-xl">{s.icon}</span>
                  <h4 class="font-semibold text-sm text-gray-100 group-hover:text-pink-400 transition-colors line-clamp-1">{s.name}</h4>
                </div>
                <p class="text-xs text-gray-400 line-clamp-2">{s.desc}</p>
              </div>
            </a>
          ))}
        </div>
        <div class="text-center">
          <a href="/stories/" class="inline-block px-6 py-2 bg-pink-500 hover:bg-pink-600 rounded-xl text-sm font-medium transition-colors">
            View All AI Story Games →
          </a>
        </div>
      </div>
    </section>

    <!-- Cross-links: Related Games & AI Hub -->
    <section class="bg-slate-900/50 border-t border-slate-800 py-8 px-4 sm:px-6">
      <div class="max-w-4xl mx-auto">
        <div class="flex flex-col md:flex-row gap-8">
          <!-- Related Games -->
          <div class="flex-1">
            <h3 class="text-lg font-semibold mb-4">You Might Also Like</h3>
            <div class="grid grid-cols-2 gap-3">
              {templateType === 'detective' && (
                <>
                  <a href="/games/crossword/" class="group block bg-slate-800/60 rounded-xl p-3 border border-slate-700/50 hover:border-slate-600 transition-all">
                    <div class="text-xl mb-1">🧩</div>
                    <h4 class="text-sm font-medium group-hover:text-green-400 transition-colors">Crossword</h4>
                  </a>
                  <a href="/games/wordle/" class="group block bg-slate-800/60 rounded-xl p-3 border border-slate-700/50 hover:border-slate-600 transition-all">
                    <div class="text-xl mb-1">📗</div>
                    <h4 class="text-sm font-medium group-hover:text-green-400 transition-colors">Wordle</h4>
                  </a>
                </>
              )}
              {templateType === 'survival' && (
                <>
                  <a href="/games/tower-defense/" class="group block bg-slate-800/60 rounded-xl p-3 border border-slate-700/50 hover:border-slate-600 transition-all">
                    <div class="text-xl mb-1">🏰</div>
                    <h4 class="text-sm font-medium group-hover:text-green-400 transition-colors">Tower Defense</h4>
                  </a>
                  <a href="/games/minesweeper/" class="group block bg-slate-800/60 rounded-xl p-3 border border-slate-700/50 hover:border-slate-600 transition-all">
                    <div class="text-xl mb-1">💣</div>
                    <h4 class="text-sm font-medium group-hover:text-green-400 transition-colors">Minesweeper</h4>
                  </a>
                </>
              )}
              {templateType === 'dating-sim' && (
                <>
                  <a href="/games/memory-match/" class="group block bg-slate-800/60 rounded-xl p-3 border border-slate-700/50 hover:border-slate-600 transition-all">
                    <div class="text-xl mb-1">🃏</div>
                    <h4 class="text-sm font-medium group-hover:text-green-400 transition-colors">Memory Match</h4>
                  </a>
                  <a href="/games/connections/" class="group block bg-slate-800/60 rounded-xl p-3 border border-slate-700/50 hover:border-slate-600 transition-all">
                    <div class="text-xl mb-1">🔗</div>
                    <h4 class="text-sm font-medium group-hover:text-green-400 transition-colors">Connections</h4>
                  </a>
                </>
              )}
              {!['detective', 'survival', 'dating-sim'].includes(templateType) && (
                <>
                  <a href="/games/2048/" class="group block bg-slate-800/60 rounded-xl p-3 border border-slate-700/50 hover:border-slate-600 transition-all">
                    <div class="text-xl mb-1">🔢</div>
                    <h4 class="text-sm font-medium group-hover:text-green-400 transition-colors">2048</h4>
                  </a>
                  <a href="/games/sudoku/" class="group block bg-slate-800/60 rounded-xl p-3 border border-slate-700/50 hover:border-slate-600 transition-all">
                    <div class="text-xl mb-1">📊</div>
                    <h4 class="text-sm font-medium group-hover:text-green-400 transition-colors">Sudoku</h4>
                  </a>
                </>
              )}
            </div>
          </div>

          <!-- AI Games Hub Link -->
          <div class="flex-1">
            <h3 class="text-lg font-semibold mb-4">More AI Experiences</h3>
            <a href="/hubs/ai-games/" class="group block bg-gradient-to-br from-pink-900/30 to-rose-900/30 border border-pink-700/30 rounded-xl p-5 hover:border-pink-500/50 transition-all">
              <div class="text-3xl mb-2">🤖</div>
              <h4 class="font-semibold group-hover:text-pink-400 transition-colors mb-1">AI Games Hub</h4>
              <p class="text-sm text-slate-400">15+ AI-powered interactive stories — romance, mystery, survival, fantasy, and more. Every playthrough is unique!</p>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="bg-slate-900 border-t border-slate-800 py-4 px-4 text-center text-sm text-slate-500">
      © 2026 Free Games Hub — Play Free Online Games
    </footer>
  </div>
</BaseLayout>

<script>
  // Back navigation for AIStoryGame component
  window.addEventListener('message', (e) => {
    if (e.data?.type === 'navigate-back') {
      window.location.href = '/stories/'
    }
  })
</script>
