---
// Story Variant Page - Programmatic SEO for seasonal/themed story variants
import BaseLayout from '../../../layouts/BaseLayout.astro'
import StoryGameWithShare from '../../../components/ai/StoryGameWithShare'
import { getAllStoryVariants, getStoryVariant, getVariantsForStory } from '../../../data/storyVariants'
import { getCollection } from 'astro:content'

export async function getStaticPaths() {
  const variants = getAllStoryVariants()
  return variants.map(variant => ({
    params: { slug: variant.storySlug, variant: variant.variant },
    props: { variant },
  }))
}

const { slug, variant: variantName } = Astro.params
const variant = getStoryVariant(slug!, variantName!)

if (!variant) {
  return Astro.redirect('/404')
}

// Load the base story template
const stories = await getCollection('stories')
const storyEntry = stories.find(s => s.data.slug === slug)
if (!storyEntry) {
  return Astro.redirect('/404')
}

const story = storyEntry.data
const storyName = variant.h1 || story.en.name
const storyDesc = variant.description
const storyIcon = story.icon
const characters = story.storySkeleton.characters
const chapters = story.storySkeleton.chapters

const seoTitle = `${variant.title} | Free Games Hub`
const seoDescription = variant.description

const breadcrumbItems = [
  { name: 'Home', url: '/' },
  { name: 'AI Stories', url: '/stories/' },
  { name: story.en.name, url: `/stories/${story.slug}/` },
  { name: variant.variant.charAt(0).toUpperCase() + variant.variant.slice(1).replace(/-/g, ' '), url: `/stories/${slug}/${variantName}/` },
]

const schema = {
  "@context": "https://schema.org",
  "@type": "VideoGame",
  "name": variant.title,
  "description": variant.description,
  "genre": "Interactive Fiction",
  "gamePlatform": "Web Browser",
  "applicationCategory": "Game",
  "operatingSystem": "Any",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "url": `https://ruleword.com/stories/${slug}/${variantName}/`,
}

// Other variants for the same story
const otherVariants = getVariantsForStory(slug!).filter(v => v.variant !== variantName)
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  keywords={variant.keywords.join(', ')}
  canonicalPath={`/stories/${slug}/${variantName}/`}
  ogImage={`/og/story-${slug}.png`}
  breadcrumbItems={breadcrumbItems}
  robots="noindex, follow"
>
  <div class="min-h-screen bg-slate-950 text-white flex flex-col">
    <!-- Navigation Bar -->
    <nav class="sticky top-0 z-50 bg-slate-950/90 border-b border-slate-800 backdrop-blur-xl">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="flex items-center justify-between h-14">
          <div class="flex items-center gap-4">
            <a href="/" class="flex items-center gap-2 hover:opacity-80 transition-opacity">
              <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-green-400 to-emerald-600 flex items-center justify-center text-white font-bold text-sm shadow-lg">R</div>
              <span class="font-semibold hidden sm:inline">Free Games Hub</span>
            </a>
          </div>
          <h1 class="text-lg font-bold truncate max-w-[200px] sm:max-w-none">{storyIcon} {variant.title.split(' - ')[0]}</h1>
          <div class="flex items-center gap-2">
            <a href={`/stories/${slug}/`} class="text-sm text-pink-400 hover:text-pink-300 transition-colors">Original Version</a>
          </div>
        </div>
      </div>
    </nav>

    <!-- Variant Banner -->
    <div class="bg-gradient-to-r from-purple-900/30 to-pink-900/30 border-b border-purple-800/50 py-3 px-4 text-center">
      <span class="text-purple-300 text-sm">
        ✨ {variant.variantType === 'seasonal' ? 'Seasonal Special' : 'Themed Edition'}:
        {variant.subtitle || variant.h1}
      </span>
    </div>

    <!-- Game Area -->
    <main class="h-[calc(100vh-7rem)] relative">
      <StoryGameWithShare
        client:load
        template={JSON.stringify(story)}
        gameName={storyName}
        gameSlug={story.slug}
        gameEmoji={storyIcon}
      />
    </main>

    <!-- SEO Content Section -->
    <section class="bg-slate-900/50 border-t border-slate-800 py-12 px-4 sm:px-6">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl font-bold mb-6">{variant.title}</h2>

        <div class="prose prose-invert max-w-none space-y-8">
          <!-- Description -->
          <div>
            <p class="text-slate-300 text-lg leading-relaxed">{variant.description}</p>
          </div>

          <!-- Tips -->
          {variant.tips && variant.tips.length > 0 && (
            <div>
              <h3 class="text-xl font-semibold text-white mb-4 flex items-center gap-2">
                <span class="text-2xl">💡</span> Tips for This Edition
              </h3>
              <ul class="space-y-2">
                {variant.tips.map(tip => (
                  <li class="flex gap-2 text-slate-300">
                    <span class="text-pink-400 shrink-0">•</span>
                    <span class="text-sm">{tip}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}

          <!-- Other Variants -->
          {otherVariants.length > 0 && (
            <div>
              <h3 class="text-xl font-semibold text-white mb-4 flex items-center gap-2">
                <span class="text-2xl">🎮</span> More Editions
              </h3>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                {otherVariants.map(v => (
                  <a
                    href={`/stories/${slug}/${v.variant}/`}
                    class="block bg-slate-800/50 rounded-xl p-4 border border-slate-700/50 hover:border-pink-500/50 transition-colors"
                  >
                    <h4 class="text-white font-semibold text-sm">{v.h1}</h4>
                    <p class="text-slate-400 text-xs mt-1 line-clamp-2">{v.description}</p>
                  </a>
                ))}
              </div>
            </div>
          )}

          <!-- Back to original -->
          <div class="text-center pt-4">
            <a
              href={`/stories/${slug}/`}
              class="inline-block px-6 py-2 bg-pink-500 hover:bg-pink-600 rounded-xl text-sm font-medium transition-colors"
            >
              Play Original Version →
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- JSON-LD Schema -->
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />

    <script>
      // Back navigation for AIStoryGame component
      window.addEventListener('message', (e) => {
        if (e.data?.type === 'navigate-back') {
          window.location.href = '/stories/'
        }
      })
    </script>

    <!-- Footer -->
    <footer class="bg-slate-900 border-t border-slate-800 py-4 px-4 text-center text-sm text-slate-500">
      © 2026 Free Games Hub — Play Free Online Games
    </footer>
  </div>
</BaseLayout>
