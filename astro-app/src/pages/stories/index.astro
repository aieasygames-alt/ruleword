---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getCollection } from 'astro:content'

const stories = await getCollection('stories')
const storyData = stories.map(entry => entry.data)

const seoTitle = 'AI Interactive Story Games - Play AI Story Games Online Free | Free Games Hub'
const seoDescription = 'Play AI-powered interactive story games online for free. Choose your path in romantic dating sims, detective mysteries, survival horror, and more. No download required!'

const breadcrumbItems = [
  { name: 'Home', url: '/' },
  { name: 'AI Stories', url: '/stories/' },
]
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  keywords="AI story games, interactive fiction, AI dating simulator, AI horror story, detective game, play online free, browser game"
  canonicalPath="/stories/"
  ogImage="/og/stories-index.png"
  breadcrumbItems={breadcrumbItems}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      "name": "AI Interactive Story Games",
      "description": seoDescription,
      "url": "https://ruleword.com/stories/",
      "mainEntity": {
        "@type": "ItemList",
        "numberOfItems": storyData.length,
        "itemListElement": storyData.map((story, i) => ({
          "@type": "ListItem",
          "position": i + 1,
          "name": story.en.name,
          "url": `https://ruleword.com/stories/${story.slug}/`
        }))
      }
    })} />
  </script>
  <div class="min-h-screen bg-slate-950 text-white">
    <!-- Navigation -->
    <nav class="sticky top-0 z-50 bg-slate-950/90 border-b border-slate-800 backdrop-blur-xl">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="flex items-center justify-between h-14">
          <a href="/" class="flex items-center gap-2 hover:opacity-80 transition-opacity">
            <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-green-400 to-emerald-600 flex items-center justify-center text-white font-bold text-sm shadow-lg">R</div>
            <span class="font-semibold hidden sm:inline">Free Games Hub</span>
          </a>
          <h1 class="text-lg font-bold">AI Story Games</h1>
          <div class="w-24" />
        </div>
      </div>
    </nav>

    <!-- Hero -->
    <section class="relative overflow-hidden bg-gradient-to-b from-slate-900 via-purple-900/20 to-slate-950 py-16 px-4">
      <div class="max-w-4xl mx-auto text-center space-y-4">
        <div class="text-5xl mb-4">🤖📖</div>
        <h2 class="text-3xl sm:text-4xl font-bold bg-gradient-to-r from-pink-400 to-purple-400 bg-clip-text text-transparent">
          AI Interactive Story Games
        </h2>
        <p class="text-slate-400 text-lg max-w-2xl mx-auto">
          Every story is unique. Our AI creates personalized narratives based on your choices. No two playthroughs are the same.
        </p>
        <div class="flex flex-wrap justify-center gap-3 text-sm">
          <span class="px-3 py-1 bg-pink-500/20 text-pink-300 rounded-full">💕 Romance</span>
          <span class="px-3 py-1 bg-purple-500/20 text-purple-300 rounded-full">🔍 Mystery</span>
          <span class="px-3 py-1 bg-red-500/20 text-red-300 rounded-full">🧠 Persuasion</span>
          <span class="px-3 py-1 bg-blue-500/20 text-blue-300 rounded-full">🚪 Escape Room</span>
          <span class="px-3 py-1 bg-amber-500/20 text-amber-300 rounded-full">⚔️ Fantasy RPG</span>
        </div>
      </div>
    </section>

    <!-- Story Cards Grid -->
    <section class="max-w-5xl mx-auto px-4 py-12">
      <div class={`grid gap-6 ${storyData.length === 1 ? 'grid-cols-1 max-w-2xl mx-auto' : 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3'}`}>
        {storyData.map(story => (
          <a
            href={`/stories/${story.slug}/`}
            class="group block bg-slate-800/50 rounded-2xl overflow-hidden border border-slate-700/50 hover:border-pink-500/50 transition-all duration-300 hover:shadow-lg hover:shadow-pink-500/10"
          >
            <div class={`h-2 bg-gradient-to-r ${story.color}`} />
            <div class="p-6 space-y-3">
              <div class="flex items-center gap-3">
                <span class="text-3xl">{story.icon}</span>
                <div>
                  <h3 class="font-bold text-white group-hover:text-pink-400 transition-colors">{story.en.name}</h3>
                  <span class="text-xs text-slate-500 uppercase tracking-wider">{story.templateType}</span>
                </div>
              </div>
              <p class="text-slate-400 text-sm leading-relaxed line-clamp-3">{story.en.desc}</p>
              <div class="flex items-center gap-2 text-xs text-slate-500">
                <span>{story.storySkeleton.characters.length} characters</span>
                <span>•</span>
                <span>{story.storySkeleton.chapters.length} chapters</span>
                <span>•</span>
                <span>{story.storySkeleton.endings.length}+ endings</span>
              </div>
              <div class="pt-2">
                <span class="inline-block px-4 py-1.5 bg-pink-500/20 text-pink-300 rounded-lg text-sm group-hover:bg-pink-500/30 transition-colors">
                  Play Now →
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- What are AI Story Games -->
    <section class="bg-slate-900/50 border-t border-slate-800 py-12 px-4">
      <div class="max-w-4xl mx-auto space-y-6">
        <h2 class="text-2xl font-bold text-center">What Are AI Story Games?</h2>
        <div class="prose prose-invert max-w-none text-slate-300">
          <p>AI Story Games are a new kind of interactive entertainment where artificial intelligence generates unique story content in real-time. Unlike traditional games with scripted storylines, every playthrough creates a different narrative based on your choices.</p>
          <p>Each game features memorable characters, branching storylines, multiple endings, and stats that track your relationships and progress. Simply read the story, make choices that feel right to you, and see where the adventure takes you!</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-center">
          <div class="bg-slate-800/50 rounded-xl p-4">
            <div class="text-2xl mb-2">🎯</div>
            <h3 class="font-semibold text-white text-sm mb-1">Choice-Driven</h3>
            <p class="text-slate-400 text-xs">Your decisions shape the entire story</p>
          </div>
          <div class="bg-slate-800/50 rounded-xl p-4">
            <div class="text-2xl mb-2">🔄</div>
            <h3 class="font-semibold text-white text-sm mb-1">Replayable</h3>
            <p class="text-slate-400 text-xs">Every playthrough is unique</p>
          </div>
          <div class="bg-slate-800/50 rounded-xl p-4">
            <div class="text-2xl mb-2">📱</div>
            <h3 class="font-semibold text-white text-sm mb-1">No Download</h3>
            <p class="text-slate-400 text-xs">Play instantly in your browser</p>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="border-t border-slate-800 py-12 px-4">
      <div class="max-w-4xl mx-auto space-y-4">
        <h2 class="text-2xl font-bold text-center mb-6">Frequently Asked Questions</h2>
        <details class="group bg-slate-800/30 rounded-lg">
          <summary class="px-4 py-3 cursor-pointer text-white font-medium hover:text-pink-400 transition-colors">Are AI story games free to play?</summary>
          <p class="px-4 pb-3 text-slate-400 text-sm">Yes! All our AI interactive story games are completely free to play in your browser. No download, registration, or payment required.</p>
        </details>
        <details class="group bg-slate-800/30 rounded-lg">
          <summary class="px-4 py-3 cursor-pointer text-white font-medium hover:text-pink-400 transition-colors">How does the AI work?</summary>
          <p class="px-4 pb-3 text-slate-400 text-sm">Our AI generates unique story content based on your choices. It considers the characters, setting, your previous decisions, and relationship dynamics to create a personalized narrative experience every time.</p>
        </details>
        <details class="group bg-slate-800/30 rounded-lg">
          <summary class="px-4 py-3 cursor-pointer text-white font-medium hover:text-pink-400 transition-colors">Can I save my progress?</summary>
          <p class="px-4 pb-3 text-slate-400 text-sm">Yes, your progress is automatically saved in your browser. If you close the tab and come back later, you can continue your story from where you left off.</p>
        </details>
        <details class="group bg-slate-800/30 rounded-lg">
          <summary class="px-4 py-3 cursor-pointer text-white font-medium hover:text-pink-400 transition-colors">Are these games appropriate for all ages?</summary>
          <p class="px-4 pb-3 text-slate-400 text-sm">Yes. All our AI story games are designed to be wholesome, family-friendly experiences. Content is kept appropriate for players of all ages.</p>
        </details>
      </div>
    </section>

    <!-- Footer -->
    <footer class="bg-slate-900 border-t border-slate-800 py-4 px-4 text-center text-sm text-slate-500">
      © 2026 Free Games Hub — <a href="/" class="text-pink-400 hover:text-pink-300">Play Free Online Games</a>
    </footer>
  </div>
</BaseLayout>
