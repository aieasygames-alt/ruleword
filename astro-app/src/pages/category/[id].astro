---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { games } from '../../data/games'
import { languages, categoryI18n, categoryDescriptions, i18n, type Language } from '../../data/i18n'

// Generate static paths for all categories - inline data to avoid hoisting issues
export function getStaticPaths() {
  const categories = [
    { id: 'word', icon: '🔤', en: 'Word Games', zh: '文字游戏' },
    { id: 'logic', icon: '🧩', en: 'Logic & Numbers', zh: '数字逻辑' },
    { id: 'strategy', icon: '♟️', en: 'Strategy', zh: '策略对战' },
    { id: 'arcade', icon: '👾', en: 'Arcade', zh: '经典街机' },
    { id: 'memory', icon: '🧠', en: 'Memory & Reflex', zh: '记忆反应' },
    { id: 'skill', icon: '🎯', en: 'Skill Games', zh: '技能挑战' },
    { id: 'puzzle', icon: '🧩', en: 'Puzzle', zh: '拼图消除' },
  ]
  return categories.map(cat => ({
    params: { id: cat.id },
    props: { category: cat }
  }))
}

const { category } = Astro.props
const categoryGames = games.filter(g => g.category === category.id)
const allLanguages = languages

// Default language for server render (client will update based on localStorage)
const defaultLang: Language = 'en'
const defaultT = i18n[defaultLang]
const defaultF = defaultT.feedback
---

<BaseLayout title={`${category.en} - RuleWord | Free Online Games`}>
  <!-- Prefetch homepage for faster navigation -->
  <link rel="prefetch" href="/" />
  <div class="min-h-screen bg-slate-950 text-white" id="app">
    <!-- Header -->
    <header class="sticky top-0 z-50 bg-slate-950/90 border-b border-slate-800 backdrop-blur-xl">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="flex items-center justify-between h-16">
          <a href="/" class="flex items-center gap-3 hover:opacity-80 transition-opacity">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-green-400 to-emerald-600 flex items-center justify-center text-white font-bold text-xl shadow-lg shadow-green-500/25">
              R
            </div>
            <div>
              <span class="text-xl font-bold tracking-tight">RuleWord</span>
              <p class="text-xs text-slate-400 -mt-0.5"><span data-i18n="gamesCount">{games.length}</span>+ <span data-i18n="freeGames">Free Games</span></p>
            </div>
          </a>

          <!-- Right: Language and Feedback -->
          <div class="flex items-center gap-2">
            <div class="relative">
              <button id="lang-btn" class="flex items-center gap-2 px-3 py-2 rounded-lg bg-slate-800 hover:bg-slate-700 transition-colors text-sm">
                <span class="text-lg">🌐</span>
                <span class="hidden sm:inline" id="current-lang">English</span>
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div id="lang-dropdown" class="absolute right-0 mt-2 w-48 bg-slate-800 rounded-lg shadow-xl z-20 py-1 border border-slate-700 hidden">
                {allLanguages.map(lang => (
                  <button onclick={`setLang('${lang.code}')`} class="w-full px-4 py-2 text-left text-sm hover:bg-slate-700 text-slate-300" data-lang-code={lang.code}>
                    {lang.nativeName}
                  </button>
                ))}
              </div>
            </div>
            <button
              id="feedback-btn"
              class="flex items-center gap-1 px-3 py-2 rounded-lg bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-500 hover:to-pink-500 transition-all text-sm font-medium"
            >
              <span>💬</span>
              <span class="hidden sm:inline" data-i18n="feedback">Feedback</span>
            </button>
          </div>
        </div>
      </div>
    </header>

    <!-- Hero -->
    <div class="relative overflow-hidden bg-gradient-to-b from-slate-900 to-slate-950">
      <div class="absolute inset-0 overflow-hidden">
        <div class="absolute -top-40 -right-40 w-80 h-80 rounded-full blur-3xl opacity-20 bg-green-500"></div>
        <div class="absolute -bottom-40 -left-40 w-80 h-80 rounded-full blur-3xl opacity-20 bg-blue-500"></div>
      </div>

      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 py-12 sm:py-16 text-center">
        <!-- Breadcrumb -->
        <div class="flex items-center justify-center gap-2 mb-4 text-sm text-slate-400">
          <a href="/" class="hover:text-white transition-colors" data-i18n="backToHome">Back to Home</a>
          <span>/</span>
          <span class="text-2xl">{category.icon}</span>
          <span class="category-name text-white font-medium">{category.en}</span>
        </div>

        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-4 tracking-tight category-name">
          {category.en}
        </h1>
        <p class="text-lg sm:text-xl max-w-2xl mx-auto text-slate-400 mb-2 category-subtitle">
          {category.zh}
        </p>
        <p class="text-sm text-slate-500">
          {categoryGames.length} <span data-i18n="gamesCount">games</span>
        </p>
      </div>
    </div>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 pb-16">
      {categoryGames.length === 0 ? (
        <div class="text-center py-20 text-slate-400">
          <p class="text-6xl mb-4">🎮</p>
          <p class="text-xl" data-i18n="noGames">No games in this category</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {categoryGames.map(game => (
            <a
              href={`/games/${game.slug}/`}
              class="group relative overflow-hidden rounded-2xl p-5 text-left transition-all duration-300 hover:shadow-xl hover:-translate-y-1 bg-slate-900/80 border border-slate-800"
              data-game-slug={game.slug}
            >
              <div class="flex items-start gap-4">
                <div class={`w-14 h-14 rounded-xl bg-gradient-to-br ${game.color} flex items-center justify-center flex-shrink-0 shadow-lg transition-transform group-hover:scale-110`}>
                  <span class="text-2xl">{game.icon}</span>
                </div>
                <div class="flex-1 min-w-0">
                  <h3 class="font-bold text-lg mb-1 game-name">{game.name}</h3>
                  <p class="text-sm text-slate-400 line-clamp-2 game-desc">{game.desc}</p>
                </div>
                <svg class="w-5 h-5 text-slate-400 group-hover:text-green-500 group-hover:translate-x-1 transition-all flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </div>
              {game.featured && (
                <div class="absolute top-3 right-3">
                  <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-gradient-to-r from-amber-400 to-orange-500 text-white">
                    ⭐
                  </span>
                </div>
              )}
            </a>
          ))}
        </div>
      )}
    </main>

    <!-- Category Description Section -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 pb-12">
      <div class="max-w-4xl mx-auto">
        <div class="bg-slate-900/50 border border-slate-800 rounded-xl p-6">
          <h2 class="text-xl font-bold mb-4" data-i18n="aboutCategory">About This Category</h2>
          <h3 class="text-lg font-semibold text-white mb-3 category-desc-title"></h3>
          <p class="text-slate-300 leading-relaxed category-desc-text"></p>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="border-t border-slate-800 bg-slate-900/50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 py-8">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-green-400 to-emerald-600 flex items-center justify-center text-white font-bold text-sm">
              R
            </div>
            <span class="font-semibold text-slate-400">RuleWord</span>
          </div>
          <p class="text-sm text-slate-400">
            <span data-i18n="copyright">© 2026 RuleWord</span> · {games.length}+ <span data-i18n="freeGames">Free Games</span>
          </p>
        </div>
      </div>
    </footer>
  </div>

  <!-- Feedback Modal -->
  <div id="feedback-modal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" onclick="document.getElementById('feedback-modal').classList.add('hidden')"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-md bg-slate-800 rounded-2xl p-6 shadow-2xl">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-bold">💬 {defaultF.title}</h3>
        <button onclick="document.getElementById('feedback-modal').classList.add('hidden')" class="text-slate-400 hover:text-white">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <form id="feedback-form" class="space-y-4">
        <div>
          <label class="block text-sm text-slate-300 mb-1">{defaultF.type}</label>
          <select id="feedback-type" class="w-full px-3 py-2 rounded-lg bg-slate-700 border border-slate-600 text-white">
            <option value="bug">🐛 {defaultF.bugReport}</option>
            <option value="feature">💡 {defaultF.featureRequest}</option>
            <option value="game">🎮 {defaultF.gameFeedback}</option>
            <option value="other">📝 {defaultF.other}</option>
          </select>
        </div>
        <div>
          <label class="block text-sm text-slate-300 mb-1">{defaultF.message}</label>
          <textarea id="feedback-message" rows="4" class="w-full px-3 py-2 rounded-lg bg-slate-700 border border-slate-600 text-white placeholder-slate-400" placeholder={defaultF.messagePlaceholder}></textarea>
        </div>
        <div>
          <label class="block text-sm text-slate-300 mb-1">{defaultF.email}</label>
          <input type="email" id="feedback-email" class="w-full px-3 py-2 rounded-lg bg-slate-700 border border-slate-600 text-white placeholder-slate-400" placeholder={defaultF.emailPlaceholder} />
        </div>
        <button type="submit" class="w-full py-2 rounded-lg bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-500 hover:to-pink-500 font-medium transition-all">
          {defaultF.send}
        </button>
      </form>
      <div id="feedback-success" class="hidden text-center py-8">
        <div class="text-4xl mb-2">✅</div>
        <p class="text-green-400 font-medium">{defaultF.success}</p>
      </div>
    </div>
  </div>

  <script define:vars={{ allLanguages, categoryI18n, categoryDescriptions, games, category, feedbackText: defaultF }}>
    // Language list and i18n data passed from server
    const languageList = allLanguages
    const catI18n = categoryI18n
    const catDesc = categoryDescriptions
    const gameData = games
    const currentCategory = category.id

    // Language names mapping
    const langNativeNames = {}
    languageList.forEach(l => { langNativeNames[l.code] = l.nativeName })

    // Get current language
    function getLang() {
      const params = new URLSearchParams(window.location.search)
      const urlLang = params.get('lang')
      const validLangs = languageList.map(l => l.code)
      if (urlLang && validLangs.includes(urlLang)) {
        localStorage.setItem('ruleword-lang', urlLang)
        return urlLang
      }
      const savedLang = localStorage.getItem('ruleword-lang')
      if (savedLang && validLangs.includes(savedLang)) return savedLang
      const browserLang = navigator.language || navigator.userLanguage
      if (browserLang) {
        if (browserLang.startsWith('zh-CN') || browserLang === 'zh-Hans') return 'zh-CN'
        if (browserLang.startsWith('zh-TW') || browserLang === 'zh-Hant' || browserLang.startsWith('zh-HK')) return 'zh-TW'
        if (browserLang.startsWith('zh')) return 'zh-CN'
        if (browserLang.startsWith('fr')) return 'fr'
        if (browserLang.startsWith('de')) return 'de'
        if (browserLang.startsWith('es')) return 'es'
        if (browserLang.startsWith('ru')) return 'ru'
        if (browserLang.startsWith('ja')) return 'ja'
      }
      return 'en'
    }

    // Set language
    function setLang(lang) {
      localStorage.setItem('ruleword-lang', lang)
      const url = new URL(window.location.href)
      url.searchParams.set('lang', lang)
      window.location.href = url.toString()
    }
    window.setLang = setLang

    // Get game name/desc by language
    function getGameNameByLang(game, lang) {
      if (lang === 'zh-CN' || lang === 'zh-TW') return game.nameZh
      return game.name
    }
    function getGameDescByLang(game, lang) {
      if (lang === 'zh-CN' || lang === 'zh-TW') return game.descZh
      return game.desc
    }

    // Apply translations
    function applyTranslations(lang) {
      // Update category name
      const catData = catI18n[lang] && catI18n[lang][currentCategory]
      if (catData) {
        document.querySelectorAll('.category-name').forEach(el => {
          el.textContent = catData.name
        })
        // Update subtitle: show English for Chinese users, show Chinese for others
        document.querySelectorAll('.category-subtitle').forEach(el => {
          const zhData = catI18n['zh-CN'] && catI18n['zh-CN'][currentCategory]
          const enData = catI18n['en'] && catI18n['en'][currentCategory]
          if (lang === 'zh-CN' || lang === 'zh-TW') {
            el.textContent = enData ? enData.name : ''
          } else {
            el.textContent = zhData ? zhData.name : ''
          }
        })
      }

      // Update category description
      const descData = catDesc[lang] && catDesc[lang][currentCategory]
      if (descData) {
        const titleEl = document.querySelector('.category-desc-title')
        const textEl = document.querySelector('.category-desc-text')
        if (titleEl) titleEl.textContent = descData.title
        if (textEl) textEl.textContent = descData.desc
      }

      // Update game names and descriptions
      document.querySelectorAll('[data-game-slug]').forEach(el => {
        const slug = el.getAttribute('data-game-slug')
        const game = gameData.find(g => g.slug === slug)
        if (game) {
          const nameEl = el.querySelector('.game-name')
          const descEl = el.querySelector('.game-desc')
          if (nameEl) nameEl.textContent = getGameNameByLang(game, lang)
          if (descEl) descEl.textContent = getGameDescByLang(game, lang)
        }
      })

      // Update UI text
      const uiTexts = {
        'backToHome': { en: 'Back to Home', 'zh-CN': '返回首页', 'zh-TW': '返回首頁', fr: 'Retour', de: 'Zurück', es: 'Volver', ru: 'На главную', ja: 'ホームに戻る' },
        'gamesCount': { en: 'games', 'zh-CN': '款游戏', 'zh-TW': '款遊戲', fr: 'jeux', de: 'Spiele', es: 'juegos', ru: 'игр', ja: 'ゲーム' },
        'freeGames': { en: 'Free Games', 'zh-CN': '免费游戏', 'zh-TW': '免費遊戲', fr: 'Jeux Gratuits', de: 'Kostenlose Spiele', es: 'Juegos Gratis', ru: 'Бесплатные Игры', ja: '無料ゲーム' },
        'copyright': { en: '© 2026 RuleWord', 'zh-CN': '© 2026 RuleWord', 'zh-TW': '© 2026 RuleWord', fr: '© 2026 RuleWord', de: '© 2026 RuleWord', es: '© 2026 RuleWord', ru: '© 2026 RuleWord', ja: '© 2026 RuleWord' },
        'aboutCategory': { en: 'About This Category', 'zh-CN': '关于此分类', 'zh-TW': '關於此分類', fr: 'À Propos', de: 'Über', es: 'Sobre', ru: 'О категории', ja: 'このカテゴリーについて' },
        'noGames': { en: 'No games in this category', 'zh-CN': '此分类暂无游戏', 'zh-TW': '此分類暫無遊戲', fr: 'Aucun jeu', de: 'Keine Spiele', es: 'Sin juegos', ru: 'Нет игр', ja: 'ゲームがありません' }
      }

      document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.getAttribute('data-i18n')
        if (uiTexts[key] && uiTexts[key][lang]) {
          el.textContent = uiTexts[key][lang]
        }
      })

      // Update current lang button
      document.getElementById('current-lang').textContent = langNativeNames[lang] || 'English'

      // Update active state in dropdown
      document.querySelectorAll('[data-lang-code]').forEach(btn => {
        const code = btn.getAttribute('data-lang-code')
        if (code === lang) {
          btn.classList.add('text-green-400')
          btn.classList.remove('text-slate-300')
        } else {
          btn.classList.remove('text-green-400')
          btn.classList.add('text-slate-300')
        }
      })
    }

    // Language dropdown toggle
    document.getElementById('lang-btn').addEventListener('click', () => {
      document.getElementById('lang-dropdown').classList.toggle('hidden')
    })

    // Close dropdown when clicking outside
    document.addEventListener('click', (e) => {
      if (!e.target.closest('#lang-btn') && !e.target.closest('#lang-dropdown')) {
        document.getElementById('lang-dropdown').classList.add('hidden')
      }
    })

    // Apply translations on load
    const currentLang = getLang()
    applyTranslations(currentLang)

    // Update game links with language parameter
    function updateGameLinks(lang) {
      document.querySelectorAll('[data-game-slug]').forEach(el => {
        if (el.tagName === 'A') {
          const slug = el.getAttribute('data-game-slug')
          const game = gameData.find(g => g.slug === slug)
          if (game) {
            const baseUrl = `/games/${game.slug}`
            el.href = lang === 'en' ? baseUrl : `${baseUrl}?lang=${lang}`
          }
        }
      })
    }
    updateGameLinks(currentLang)

    // Feedback modal
    document.getElementById('feedback-btn')?.addEventListener('click', () => {
      document.getElementById('feedback-modal')?.classList.remove('hidden')
    })

    document.getElementById('feedback-form')?.addEventListener('submit', async (e) => {
      e.preventDefault()
      const form = e.target
      const submitBtn = form.querySelector('button[type="submit"]')

      submitBtn.disabled = true
      submitBtn.textContent = feedbackText.sending

      const data = {
        type: document.getElementById('feedback-type').value,
        message: document.getElementById('feedback-message').value,
        email: document.getElementById('feedback-email').value,
        category: currentCategory,
      }

      try {
        const response = await fetch('https://api.emailjs.com/api/v1.0/email/send', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            service_id: 'service_2v1599e',
            template_id: 'template_9ee29rl',
            user_id: 'A73GlvN7cp09bDjon',
            template_params: {
              from_email: data.email || 'anonymous@ruleword.com',
              from_name: 'RuleWord User',
              message: `Type: ${data.type}\nCategory: ${data.category}\n\n${data.message}`,
            }
          })
        })

        if (response.ok) {
          form.classList.add('hidden')
          document.getElementById('feedback-success')?.classList.remove('hidden')
        } else {
          throw new Error('Failed to send')
        }
      } catch (err) {
        submitBtn.disabled = false
        submitBtn.textContent = feedbackText.send
        alert(feedbackText.fail)
      }
    })
  </script>
</BaseLayout>
