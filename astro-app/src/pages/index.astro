---
import BaseLayout from '../layouts/BaseLayout.astro'
import LanguageSelector from '../components/LanguageSelector'
import { games } from '../data/games'
import { i18n, type Language, languages } from '../data/i18n'

const featuredGames = games.filter(g => g.featured)

// Get language from URL parameter, default to 'en'
const urlLang = Astro.url.searchParams.get('lang') as string
const lang: Language = languages.some(l => l.code === urlLang) ? (urlLang as Language) : 'en'
const t = i18n[lang]

// Helper to get localized game name/desc
const getGameName = (game: typeof games[0]) => lang === 'zh-CN' || lang === 'zh-TW' ? game.nameZh : game.name
const getGameDesc = (game: typeof games[0]) => lang === 'zh-CN' || lang === 'zh-TW' ? game.descZh : game.desc
---

<BaseLayout title="RuleWord - Free Online Puzzle Games | 27+ Games">
  <div class="min-h-screen bg-slate-950 text-white">
    <!-- Header -->
    <header class="sticky top-0 z-50 bg-slate-950/90 border-b border-slate-800 backdrop-blur-xl">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="flex items-center justify-between h-16">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-green-400 to-emerald-600 flex items-center justify-center text-white font-bold text-xl shadow-lg shadow-green-500/25">
              R
            </div>
            <div>
              <h1 class="text-xl font-bold tracking-tight">RuleWord</h1>
              <p class="text-xs text-slate-400 -mt-0.5">{games.length}+ {t.home.freeGames}</p>
            </div>
          </div>

          <!-- Right: Language and Feedback -->
          <div class="flex items-center gap-2">
            <LanguageSelector client:load currentLang={lang} onLanguageChange={(newLang: Language) => {
              const url = new URL(window.location.href)
              url.searchParams.set('lang', newLang)
              window.location.href = url.toString()
            }} />
            <button
              id="feedback-btn"
              class="flex items-center gap-1 px-3 py-2 rounded-lg bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-500 hover:to-pink-500 transition-all text-sm font-medium"
            >
              <span>💬</span>
              <span class="hidden sm:inline">{t.nav.feedback}</span>
            </button>
          </div>
        </div>
      </div>
    </header>

    <!-- Hero -->
    <div class="relative overflow-hidden bg-gradient-to-b from-slate-900 to-slate-950">
      <div class="absolute inset-0 overflow-hidden">
        <div class="absolute -top-40 -right-40 w-80 h-80 rounded-full blur-3xl opacity-20 bg-green-500"></div>
        <div class="absolute -bottom-40 -left-40 w-80 h-80 rounded-full blur-3xl opacity-20 bg-blue-500"></div>
      </div>

      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 py-12 sm:py-16 text-center">
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-4 tracking-tight">
          {t.home.title}
        </h2>
        <p class="text-lg sm:text-xl max-w-2xl mx-auto text-slate-400 mb-8">
          {t.home.subtitle}
        </p>
      </div>
    </div>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 pb-16">
      <!-- Featured Section -->
      <section class="mt-8 mb-12">
        <div class="flex items-center gap-3 mb-6">
          <span class="text-2xl">⭐</span>
          <h3 class="text-xl font-bold">{t.home.featured}</h3>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
          {featuredGames.map(game => (
            <a
              href={`/games/${game.slug}`}
              class={`group relative overflow-hidden rounded-2xl aspect-square p-5 text-left transition-all duration-300 hover:scale-[1.02] hover:shadow-2xl bg-gradient-to-br ${game.color}`}
            >
              <div class="relative z-10 h-full flex flex-col justify-between">
                <div class="text-4xl lg:text-5xl">{game.icon}</div>
                <div>
                  <h4 class="font-bold text-white text-lg mb-1">{getGameName(game)}</h4>
                  <p class="text-white/80 text-sm line-clamp-2">{getGameDesc(game)}</p>
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>

      <!-- All Games -->
      <section>
        <div class="flex items-center gap-3 mb-6">
          <span class="text-2xl">🎮</span>
          <h3 class="text-xl font-bold">{t.home.allGames}</h3>
          <span class="text-sm text-slate-400">{games.length} {t.home.gamesCount}</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {games.map(game => (
            <a
              href={`/games/${game.slug}`}
              class="group relative overflow-hidden rounded-2xl p-5 text-left transition-all duration-300 hover:shadow-xl hover:-translate-y-1 bg-slate-900/80 border border-slate-800"
            >
              <div class="flex items-start gap-4">
                <div class={`w-14 h-14 rounded-xl bg-gradient-to-br ${game.color} flex items-center justify-center flex-shrink-0 shadow-lg transition-transform group-hover:scale-110`}>
                  <span class="text-2xl">{game.icon}</span>
                </div>
                <div class="flex-1 min-w-0">
                  <h4 class="font-bold text-lg mb-1">{getGameName(game)}</h4>
                  <p class="text-sm text-slate-400 line-clamp-2">{getGameDesc(game)}</p>
                </div>
                <svg class="w-5 h-5 text-slate-400 group-hover:text-green-500 group-hover:translate-x-1 transition-all flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </div>
              {game.featured && (
                <div class="absolute top-3 right-3">
                  <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-gradient-to-r from-amber-400 to-orange-500 text-white">
                    ⭐
                  </span>
                </div>
              )}
            </a>
          ))}
        </div>
      </section>
    </main>

    <!-- Footer -->
    <footer class="border-t border-slate-800 bg-slate-900/50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 py-8">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-green-400 to-emerald-600 flex items-center justify-center text-white font-bold text-sm">
              R
            </div>
            <span class="font-semibold text-slate-400">RuleWord</span>
          </div>
          <p class="text-sm text-slate-400">
            {t.footer.copyright} · {games.length}+ {t.home.freeGames}
          </p>
        </div>
      </div>
    </footer>
  </div>

  <!-- Feedback Modal -->
  <div id="feedback-modal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" onclick="document.getElementById('feedback-modal').classList.add('hidden')"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-md bg-slate-800 rounded-2xl p-6 shadow-2xl">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-bold">💬 Feedback</h3>
        <button onclick="document.getElementById('feedback-modal').classList.add('hidden')" class="text-slate-400 hover:text-white">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <form id="feedback-form" class="space-y-4">
        <div>
          <label class="block text-sm text-slate-300 mb-1">Type</label>
          <select id="feedback-type" class="w-full px-3 py-2 rounded-lg bg-slate-700 border border-slate-600 text-white">
            <option value="bug">🐛 Bug Report</option>
            <option value="feature">💡 Feature Request</option>
            <option value="game">🎮 Game Feedback</option>
            <option value="other">📝 Other</option>
          </select>
        </div>
        <div>
          <label class="block text-sm text-slate-300 mb-1">Message</label>
          <textarea id="feedback-message" rows="4" class="w-full px-3 py-2 rounded-lg bg-slate-700 border border-slate-600 text-white placeholder-slate-400" placeholder="Describe your feedback..."></textarea>
        </div>
        <div>
          <label class="block text-sm text-slate-300 mb-1">Email (optional)</label>
          <input type="email" id="feedback-email" class="w-full px-3 py-2 rounded-lg bg-slate-700 border border-slate-600 text-white placeholder-slate-400" placeholder="For reply" />
        </div>
        <button type="submit" class="w-full py-2 rounded-lg bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-500 hover:to-pink-500 font-medium transition-all">
          Send Feedback
        </button>
      </form>
      <div id="feedback-success" class="hidden text-center py-8">
        <div class="text-4xl mb-2">✅</div>
        <p class="text-green-400 font-medium">Thank you for your feedback!</p>
      </div>
    </div>
  </div>

  <script>
    // Feedback modal
    document.getElementById('feedback-btn')?.addEventListener('click', () => {
      document.getElementById('feedback-modal')?.classList.remove('hidden')
    })

    document.getElementById('feedback-form')?.addEventListener('submit', async (e) => {
      e.preventDefault()
      const form = e.target as HTMLFormElement
      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement

      submitBtn.disabled = true
      submitBtn.textContent = 'Sending...'

      const data = {
        type: (document.getElementById('feedback-type') as HTMLSelectElement).value,
        message: (document.getElementById('feedback-message') as HTMLTextAreaElement).value,
        email: (document.getElementById('feedback-email') as HTMLInputElement).value,
      }

      try {
        const response = await fetch('https://api.emailjs.com/api/v1.0/email/send', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            service_id: 'service_2v1599e',
            template_id: 'template_9ee29rl',
            user_id: 'A73GlvN7cp09bDjon',
            template_params: {
              from_email: data.email || 'anonymous@ruleword.com',
              from_name: 'RuleWord User',
              message: `Type: ${data.type}\n\n${data.message}`,
            }
          })
        })

        if (response.ok) {
          form.classList.add('hidden')
          document.getElementById('feedback-success')?.classList.remove('hidden')
        } else {
          throw new Error('Failed to send')
        }
      } catch (err) {
        submitBtn.disabled = false
        submitBtn.textContent = 'Send Feedback'
        alert('Failed to send feedback. Please try again.')
      }
    })
  </script>
</BaseLayout>
