---
import BaseLayout from '../layouts/BaseLayout.astro'
import { getCollection } from 'astro:content'
import { categories } from '../data/games'
import { languages, i18n, categoryI18n, type Language } from '../data/i18n'
import { homepageSEO } from '../data/seo'
import { gameGuides } from '../data/gameGuidesSEO'
import GameSearch from '../components/GameSearch.astro'
import GameShowcase from '../components/GameShowcase.astro'

// 从 CMS Content Collections 获取所有游戏
const gamesCollection = await getCollection('games')
const games = gamesCollection.map(entry => ({
  ...entry.data,
  // 兼容旧格式
  name: entry.data.en.name,
  nameZh: entry.data.zh?.name || entry.data.en.name,
  desc: entry.data.en.desc,
  descZh: entry.data.zh?.desc || entry.data.en.desc
}))

const featuredGames = games.filter(g => g.featured).slice(0, 8)
const categoryList = categories.filter(c => c.id !== 'all')

// Quick Play - 6 universally popular games
const quickPlaySlugs = ['wordle', 'sudoku', '2048', 'tetris', 'chess', 'pac-man']
const quickPlayGames = quickPlaySlugs.map(slug => games.find(g => g.slug === slug)).filter(Boolean)

// Get all language codes for dropdown
const allLanguages = languages
const categoryI18nData = categoryI18n

---

<BaseLayout
  title={homepageSEO.title}
  description={homepageSEO.description}
  keywords={homepageSEO.keywords}
  isHomePage={true}
>
  <div class="min-h-screen bg-gray-50 text-gray-900 dark:bg-slate-950 dark:text-white" id="app">
    <!-- Header -->
    <header class="sticky top-0 z-50 bg-white/90 dark:bg-slate-950/90 border-b border-gray-200 dark:border-slate-800 backdrop-blur-xl">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="flex items-center justify-between h-16">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-green-400 to-emerald-600 flex items-center justify-center text-white font-bold text-xl shadow-lg shadow-green-500/25">
              R
            </div>
            <div>
              <span class="text-xl font-bold tracking-tight">Free Games Hub</span>
              <p class="text-xs text-gray-600 dark:text-slate-400 -mt-0.5"><span data-i18n="gamesCount">{games.length}</span>+ <span data-i18n="freeGames">Free Games</span></p>
            </div>
          </div>

          <!-- Right: Language and Feedback -->
          <div class="flex items-center gap-2">
            <div class="relative">
              <button id="lang-btn" class="flex items-center gap-2 px-3 py-2 rounded-lg bg-gray-100 dark:bg-slate-800 hover:bg-gray-200 dark:hover:bg-slate-700 transition-colors text-sm text-gray-700 dark:text-slate-300">
                <span class="text-lg">🌐</span>
                <span class="hidden sm:inline" id="current-lang">English</span>
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div id="lang-dropdown" class="absolute right-0 mt-2 w-48 bg-white dark:bg-slate-800 rounded-lg shadow-xl z-20 py-1 border border-gray-200 dark:border-slate-700 hidden">
                {allLanguages.map(lang => (
                  <button onclick={`setLang('${lang.code}')`} class="w-full px-4 py-2 text-left text-sm hover:bg-gray-100 dark:hover:bg-slate-700 text-gray-700 dark:text-slate-300" data-lang-code={lang.code}>
                    {lang.nativeName}
                  </button>
                ))}
              </div>
            </div>
            <button
              id="theme-toggle-btn"
              class="flex items-center gap-1 px-3 py-2 rounded-lg bg-gray-100 dark:bg-slate-800 hover:bg-gray-200 dark:hover:bg-slate-700 transition-colors text-sm text-gray-700 dark:text-slate-300"
              aria-label="Toggle theme"
            >
              <span class="text-lg theme-icon">🌙</span>
              <span class="hidden sm:inline theme-text">Dark</span>
            </button>
            <button
              id="feedback-btn"
              class="flex items-center gap-1 px-3 py-2 rounded-lg bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-500 hover:to-pink-500 transition-all text-sm font-medium text-white"
            >
              <span>💬</span>
              <span class="hidden sm:inline" data-i18n="feedback">Feedback</span>
            </button>
          </div>
        </div>
      </div>
    </header>

    <!-- Hero -->
    <div class="relative overflow-hidden bg-gradient-to-b from-gray-100 to-gray-50 dark:from-slate-900 dark:to-slate-950">
      <div class="absolute inset-0 overflow-hidden">
        <div class="absolute -top-40 -right-40 w-80 h-80 rounded-full blur-3xl opacity-20 bg-green-500"></div>
        <div class="absolute -bottom-40 -left-40 w-80 h-80 rounded-full blur-3xl opacity-20 bg-blue-500"></div>
      </div>

      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 py-8 sm:py-10 text-center">
        <h1 class="text-2xl sm:text-3xl lg:text-4xl font-bold mb-3 tracking-tight text-gray-900 dark:text-white" data-i18n="title">
          Free Online Puzzle Games
        </h1>
        <p class="text-lg sm:text-xl max-w-2xl mx-auto text-gray-600 dark:text-slate-400 mb-8" data-i18n="subtitle">
          Classic puzzles, strategy games, arcade fun. No downloads, play instantly.
        </p>

        <!-- Search Bar -->
        <GameSearch games={games} />
      </div>
    </div>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 pb-16">
      <!-- Quick Play Section -->
      <section class="mt-8 mb-10">
        <div class="flex items-center gap-3 mb-2">
          <span class="text-2xl">🚀</span>
          <h2 class="text-xl font-bold text-gray-900 dark:text-white" data-i18n="quickPlay">Quick Play</h2>
        </div>
        <p class="text-sm text-gray-600 dark:text-slate-400 mb-4" data-i18n="quickPlayDesc">Jump right into our most popular games</p>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
          {quickPlayGames.map(game => (
            <a
              href={`/games/${game.slug}/`}
              class={`group relative overflow-hidden rounded-2xl aspect-[4/3] p-4 text-left transition-all duration-300 hover:scale-[1.02] hover:shadow-2xl bg-gradient-to-br ${game.color}`}
              data-game-slug={game.slug}
            >
              <div class="relative z-10 h-full flex flex-col justify-between">
                <div class="text-3xl lg:text-4xl">{game.icon}</div>
                <div>
                  <h3 class="font-bold text-white text-sm sm:text-base mb-0.5 game-name">{game.name}</h3>
                  <p class="text-white/80 text-xs line-clamp-1 game-desc">{game.desc}</p>
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>

      <!-- Browse by Category -->
      <section class="mb-10">
        <div class="flex items-center gap-3 mb-5">
          <span class="text-2xl">📂</span>
          <h2 class="text-xl font-bold text-gray-900 dark:text-white" data-i18n="browseByCategory">Browse by Category</h2>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
          {categoryList.map(cat => {
            const catGames = games.filter(g => g.category === cat.id)
            const previewGames = catGames.slice(0, 3)
            return (
              <a
                href={`/category/${cat.id}/`}
                class="group relative overflow-hidden rounded-xl p-4 transition-all duration-300 hover:scale-[1.01] hover:shadow-lg bg-white dark:bg-slate-900/80 border border-gray-200 dark:border-slate-800 hover:border-gray-300 dark:hover:border-slate-600"
                data-category-id={cat.id}
              >
                <div class="flex items-center gap-3 mb-3">
                  <span class="text-2xl">{cat.icon}</span>
                  <div>
                    <h4 class="font-semibold text-gray-900 dark:text-white text-sm category-name">{cat.name}</h4>
                    <p class="text-xs text-gray-500 dark:text-slate-500">{catGames.length} <span data-i18n="gamesCount">games</span></p>
                  </div>
                </div>
                <div class="flex items-center gap-2">
                  {previewGames.map(pg => (
                    <span
                      class={`w-9 h-9 rounded-lg bg-gradient-to-br ${pg.color} flex items-center justify-center text-base shadow`}
                    >
                      {pg.icon}
                    </span>
                  ))}
                  {catGames.length > 3 && (
                    <span class="w-9 h-9 rounded-lg bg-gray-100 dark:bg-slate-800 flex items-center justify-center text-xs text-gray-500 dark:text-slate-500 font-medium">
                      +{catGames.length - 3}
                    </span>
                  )}
                </div>
              </a>
            )
          })}
        </div>
      </section>

      <!-- Brain Tests Section -->
      <section class="mb-10">
        <div class="flex items-center justify-between mb-5">
          <div class="flex items-center gap-3">
            <span class="text-2xl">🧠</span>
            <h2 class="text-xl font-bold text-gray-900 dark:text-white" data-i18n="brainTests">Brain Tests & Cognitive Challenges</h2>
          </div>
        </div>
        <p class="text-sm text-gray-600 dark:text-slate-400 mb-4" data-i18n="brainTestsDesc">Test your memory, reaction speed, and cognitive control with these popular brain challenges!</p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <a href="/games/chimp-test/" class="group relative overflow-hidden rounded-2xl p-5 text-left transition-all duration-300 hover:scale-[1.02] hover:shadow-2xl bg-gradient-to-br from-amber-500 to-yellow-600">
            <div class="relative z-10">
              <div class="text-4xl mb-3">🐒</div>
              <h3 class="font-bold text-white text-lg mb-1">Chimp Test</h3>
              <p class="text-white/90 text-sm mb-3">Can you beat a chimpanzee at memory? Remember number positions and prove your skills!</p>
              <div class="flex flex-wrap gap-1">
                <span class="text-[10px] px-2 py-0.5 rounded-full bg-white/20 text-white">chimp memory test</span>
                <span class="text-[10px] px-2 py-0.5 rounded-full bg-white/20 text-white">beat a chimp</span>
              </div>
            </div>
          </a>
          <a href="/games/stroop-test/" class="group relative overflow-hidden rounded-2xl p-5 text-left transition-all duration-300 hover:scale-[1.02] hover:shadow-2xl bg-gradient-to-br from-fuchsia-500 to-pink-600">
            <div class="relative z-10">
              <div class="text-4xl mb-3">🎨</div>
              <h3 class="font-bold text-white text-lg mb-1">Stroop Test</h3>
              <p class="text-white/90 text-sm mb-3">Test your cognitive control! Match colors to words in this famous psychology experiment.</p>
              <div class="flex flex-wrap gap-1">
                <span class="text-[10px] px-2 py-0.5 rounded-full bg-white/20 text-white">stroop effect</span>
                <span class="text-[10px] px-2 py-0.5 rounded-full bg-white/20 text-white">color word test</span>
              </div>
            </div>
          </a>
          <a href="/games/aim-trainer/" class="group relative overflow-hidden rounded-2xl p-5 text-left transition-all duration-300 hover:scale-[1.02] hover:shadow-2xl bg-gradient-to-br from-red-500 to-orange-600">
            <div class="relative z-10">
              <div class="text-4xl mb-3">🎯</div>
              <h3 class="font-bold text-white text-lg mb-1">Aim Trainer</h3>
              <p class="text-white/90 text-sm mb-3">Improve your mouse accuracy! Perfect for FPS gamers looking to sharpen their aim.</p>
              <div class="flex flex-wrap gap-1">
                <span class="text-[10px] px-2 py-0.5 rounded-full bg-white/20 text-white">aim trainer</span>
                <span class="text-[10px] px-2 py-0.5 rounded-full bg-white/20 text-white">click accuracy</span>
              </div>
            </div>
          </a>
        </div>
      </section>

      <!-- Favorites & Recently Played (client-side) -->
      <section id="personalized-games" class="mb-10">
        <div id="favorites-section" class="hidden">
          <div class="flex items-center justify-between gap-3 mb-4">
            <div class="flex items-center gap-3">
              <span class="text-2xl">❤️</span>
              <h2 class="text-xl font-bold text-gray-900 dark:text-white" data-i18n="favorites">Favorite Games</h2>
            </div>
            <button id="clear-favorites-btn" class="text-sm text-gray-600 dark:text-slate-400 hover:text-red-600 dark:hover:text-red-400 transition-colors">Clear All</button>
          </div>
          <div id="favorites-grid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3"></div>
        </div>
        <div id="recent-section" class="hidden mt-8">
          <div class="flex items-center justify-between gap-3 mb-4">
            <div class="flex items-center gap-3">
              <span class="text-2xl">🕐</span>
              <h2 class="text-xl font-bold text-gray-900 dark:text-white" data-i18n="recentlyPlayed">Recently Played</h2>
            </div>
            <button id="clear-recent-btn" class="text-sm text-gray-600 dark:text-slate-400 hover:text-red-600 dark:hover:text-red-400 transition-colors">Clear All</button>
          </div>
          <div id="recent-grid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3"></div>
        </div>
      </section>

      <!-- All Games with Tab Filtering -->
      <section class="mb-10">
        <div class="flex items-center gap-3 mb-5">
          <span class="text-2xl">🎮</span>
          <h2 class="text-xl font-bold text-gray-900 dark:text-white" data-i18n="allGames">All Games</h2>
          <span class="text-sm text-gray-600 dark:text-slate-400">{games.length} <span data-i18n="gamesCount">games</span></span>
        </div>
        <!-- Category Tabs -->
        <div class="flex gap-2 overflow-x-auto pb-3 mb-4 scrollbar-thin" id="all-games-tabs">
          <button data-filter="all" class="all-games-tab active px-3 py-1.5 rounded-lg text-sm font-medium whitespace-nowrap transition-all bg-green-600 text-white" data-i18n="allGames">All Games</button>
          {categoryList.map(cat => (
            <button
              data-filter={cat.id}
              class="all-games-tab px-3 py-1.5 rounded-lg text-sm font-medium whitespace-nowrap transition-all bg-gray-100 dark:bg-slate-800 text-gray-700 dark:text-slate-300 hover:bg-gray-200 dark:hover:bg-slate-700"
              data-category-id={cat.id}
            >
              <span class="mr-1">{cat.icon}</span>
              <span class="category-name">{cat.name}</span>
            </button>
          ))}
        </div>
        <!-- Games Grid -->
        <div id="all-games-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {games.map(game => (
            <a
              href={`/games/${game.slug}/`}
              class="game-card-all group relative overflow-hidden rounded-2xl p-5 text-left transition-all duration-300 hover:shadow-xl hover:-translate-y-1 bg-white dark:bg-slate-900/80 border border-gray-200 dark:border-slate-800"
              data-game-slug={game.slug}
              data-game-category={game.category}
            >
              <div class="flex items-start gap-4">
                <div class={`w-14 h-14 rounded-xl bg-gradient-to-br ${game.color} flex items-center justify-center flex-shrink-0 shadow-lg transition-transform group-hover:scale-110`}>
                  <span class="text-2xl">{game.icon}</span>
                </div>
                <div class="flex-1 min-w-0">
                  <h3 class="font-bold text-lg mb-1 game-name text-gray-900 dark:text-white">{game.name}</h3>
                  <p class="text-sm text-gray-600 dark:text-slate-400 line-clamp-2 game-desc">{game.desc}</p>
                </div>
                <svg class="w-5 h-5 text-gray-400 dark:text-slate-400 group-hover:text-green-500 group-hover:translate-x-1 transition-all flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </div>
              {game.featured && (
                <div class="absolute top-3 right-3">
                  <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-gradient-to-r from-amber-400 to-orange-500 text-white">⭐</span>
                </div>
              )}
            </a>
          ))}
        </div>
      </section>

      <!-- Game Guides Section (top 3 only) -->
      <section class="mb-10">
        <div class="flex items-center justify-between mb-5">
          <div class="flex items-center gap-3">
            <span class="text-2xl">📖</span>
            <h2 class="text-xl font-bold text-gray-900 dark:text-white" data-i18n="gameGuides">Game Guides</h2>
          </div>
          <a href="/guides/" class="text-sm text-emerald-600 dark:text-emerald-400 hover:underline font-medium" data-i18n="viewAllGuides">View All Guides →</a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {Object.values(gameGuides).slice(0, 3).map(guide => {
            const game = games.find(g => g.slug === guide.slug)
            return (
              <a
                href={`/guides/${guide.slug}/`}
                class="group block rounded-xl p-5 transition-all duration-300 hover:scale-[1.02] hover:shadow-lg bg-white dark:bg-slate-900/80 border border-gray-200 dark:border-slate-800 hover:border-emerald-300 dark:hover:border-emerald-700"
              >
                <div class="flex items-start gap-3">
                  <span class="text-2xl shrink-0">{game?.icon || '🎮'}</span>
                  <div class="min-w-0">
                    <h3 class="font-semibold text-gray-900 dark:text-white text-sm group-hover:text-emerald-600 dark:group-hover:text-emerald-400 line-clamp-2">{guide.title}</h3>
                    <p class="text-xs text-gray-500 dark:text-slate-400 mt-1 line-clamp-2">{guide.description}</p>
                    <div class="flex flex-wrap gap-1 mt-2">
                      {guide.keywords.slice(0, 3).map(kw => (
                        <span class="inline-block text-[10px] px-1.5 py-0.5 rounded bg-emerald-50 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-300">{kw}</span>
                      ))}
                    </div>
                  </div>
                </div>
              </a>
            )
          })}
        </div>
      </section>

      <!-- About Free Games Hub Section -->
      <section class="mt-16 mb-12">
        <div class="max-w-4xl mx-auto">
          <h3 class="text-2xl font-bold text-center mb-8 text-gray-900 dark:text-white" data-i18n="aboutTitle">About Free Games Hub</h3>

          <!-- Features Grid -->
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
            <div class="bg-white dark:bg-slate-900/80 border border-gray-200 dark:border-slate-800 rounded-xl p-5 text-center">
              <div class="text-3xl mb-3">🎮</div>
              <h4 class="font-bold text-gray-900 dark:text-white mb-2" data-i18n="feature1Title">100% Free & Unlimited</h4>
              <p class="text-sm text-gray-600 dark:text-slate-400" data-i18n="feature1Desc">Play all games without any cost or time limits. No registration required.</p>
            </div>
            <div class="bg-white dark:bg-slate-900/80 border border-gray-200 dark:border-slate-800 rounded-xl p-5 text-center">
              <div class="text-3xl mb-3">⚡</div>
              <h4 class="font-bold text-gray-900 dark:text-white mb-2" data-i18n="feature2Title">Instant Play, No Downloads</h4>
              <p class="text-sm text-gray-600 dark:text-slate-400" data-i18n="feature2Desc">All games run directly in your browser. No app installation needed.</p>
            </div>
            <div class="bg-white dark:bg-slate-900/80 border border-gray-200 dark:border-slate-800 rounded-xl p-5 text-center">
              <div class="text-3xl mb-3">📱</div>
              <h4 class="font-bold text-gray-900 dark:text-white mb-2" data-i18n="feature3Title">Play Anywhere</h4>
              <p class="text-sm text-gray-600 dark:text-slate-400" data-i18n="feature3Desc">Works on desktop, tablet, and mobile devices. Enjoy games on the go.</p>
            </div>
            <div class="bg-white dark:bg-slate-900/80 border border-gray-200 dark:border-slate-800 rounded-xl p-5 text-center">
              <div class="text-3xl mb-3">🧩</div>
              <h4 class="font-bold text-gray-900 dark:text-white mb-2" data-i18n="feature4Title">Brain Training</h4>
              <p class="text-sm text-gray-600 dark:text-slate-400" data-i18n="feature4Desc">Improve your logic, vocabulary, memory and reflexes with our puzzles.</p>
            </div>
            <div class="bg-white dark:bg-slate-900/80 border border-gray-200 dark:border-slate-800 rounded-xl p-5 text-center">
              <div class="text-3xl mb-3">🌐</div>
              <h4 class="font-bold text-gray-900 dark:text-white mb-2" data-i18n="feature5Title">Multi-Language Support</h4>
              <p class="text-sm text-gray-600 dark:text-slate-400" data-i18n="feature5Desc">Available in 8 languages including English, Chinese, Japanese and more.</p>
            </div>
            <div class="bg-white dark:bg-slate-900/80 border border-gray-200 dark:border-slate-800 rounded-xl p-5 text-center">
              <div class="text-3xl mb-3">🆕</div>
              <h4 class="font-bold text-gray-900 dark:text-white mb-2" data-i18n="feature6Title">Always Growing</h4>
              <p class="text-sm text-gray-600 dark:text-slate-400" data-i18n="feature6Desc">New games added regularly. Fresh challenges await you every week.</p>
            </div>
          </div>

          <!-- About Paragraph -->
          <div class="bg-white/50 dark:bg-slate-900/50 border border-gray-200 dark:border-slate-800 rounded-xl p-6 text-center">
            <p class="text-gray-700 dark:text-slate-300 leading-relaxed" data-i18n="aboutDesc">
              Free Games Hub is your ultimate destination for free online puzzle games...
            </p>
          </div>

          <!-- FAQ Section for SEO -->
          <div class="mt-8 bg-white/50 dark:bg-slate-900/50 border border-gray-200 dark:border-slate-800 rounded-xl p-6">
            <h4 class="text-xl font-bold text-gray-900 dark:text-white mb-4 text-center">Frequently Asked Questions</h4>
            <div class="space-y-4 text-left">
              <div class="border-b border-gray-200 dark:border-slate-700 pb-4">
                <h5 class="font-semibold text-gray-900 dark:text-white mb-2">❓ Are all games really free?</h5>
                <p class="text-sm text-gray-600 dark:text-slate-400">Yes! All 111+ games on Free Games Hub are completely free to play with no hidden costs, subscriptions, or in-app purchases.</p>
              </div>
              <div class="border-b border-gray-200 dark:border-slate-700 pb-4">
                <h5 class="font-semibold text-gray-900 dark:text-white mb-2">❓ Do I need to create an account?</h5>
                <p class="text-sm text-gray-600 dark:text-slate-400">No registration required! Simply visit any game page and start playing instantly. Your progress is saved locally in your browser.</p>
              </div>
              <div class="border-b border-gray-200 dark:border-slate-700 pb-4">
                <h5 class="font-semibold text-gray-900 dark:text-white mb-2">❓ Can I play on mobile devices?</h5>
                <p class="text-sm text-gray-600 dark:text-slate-400">Absolutely! All games are fully responsive and work on desktop computers, tablets, and mobile phones. No app download needed.</p>
              </div>
              <div class="border-b border-gray-200 dark:border-slate-700 pb-4">
                <h5 class="font-semibold text-gray-900 dark:text-white mb-2">❓ What types of games are available?</h5>
                <p class="text-sm text-gray-600 dark:text-slate-400">We offer 7 categories: Word Games (Wordle, Spelling Bee), Logic & Numbers (Sudoku, 2048), Strategy (Chess, Gomoku), Arcade (Tetris, Snake), Memory & Reflex games, Skill games, and Puzzles.</p>
              </div>
              <div class="pb-2">
                <h5 class="font-semibold text-gray-900 dark:text-white mb-2">❓ How often are new games added?</h5>
                <p class="text-sm text-gray-600 dark:text-slate-400">We add new games regularly, typically several new games each month. Check back often for fresh challenges!</p>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>

    <!-- Footer -->
    <footer class="border-t border-gray-200 dark:border-slate-800 bg-gray-50/50 dark:bg-slate-900/50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 py-8">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-green-400 to-emerald-600 flex items-center justify-center text-white font-bold text-sm shadow">
              R
            </div>
            <span class="font-semibold text-gray-600 dark:text-slate-400">Free Games Hub</span>
          </div>
          <div class="flex items-center gap-4">
            <a href="/guides/" class="text-sm text-gray-600 dark:text-slate-400 hover:text-emerald-600 dark:hover:text-emerald-400 transition-colors" data-i18n="gameGuides">Game Guides</a>
            <span class="text-gray-300 dark:text-slate-700">|</span>
            <p class="text-sm text-gray-600 dark:text-slate-400">
              <span data-i18n="copyright">© 2026 Free Games Hub</span> · <span data-i18n="gamesCount">{games.length}</span>+ <span data-i18n="freeGames">Free Games</span>
            </p>
          </div>
        </div>
      </div>
    </footer>
  </div>

  <!-- Feedback Modal -->
  <div id="feedback-modal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" onclick="document.getElementById('feedback-modal').classList.add('hidden')"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-md bg-white dark:bg-slate-800 rounded-2xl p-6 shadow-2xl">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-bold text-gray-900 dark:text-white">💬 Feedback</h3>
        <button onclick="document.getElementById('feedback-modal').classList.add('hidden')" class="text-gray-400 dark:text-slate-400 hover:text-gray-600 dark:hover:text-white">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <form id="feedback-form" class="space-y-4">
        <div>
          <label class="block text-sm text-gray-700 dark:text-slate-300 mb-1">Type</label>
          <select id="feedback-type" class="w-full px-3 py-2 rounded-lg bg-gray-100 dark:bg-slate-700 border border-gray-300 dark:border-slate-600 text-gray-900 dark:text-white">
            <option value="bug">🐛 Bug Report</option>
            <option value="feature">💡 Feature Request</option>
            <option value="game">🎮 Game Feedback</option>
            <option value="other">📝 Other</option>
          </select>
        </div>
        <div>
          <label class="block text-sm text-gray-700 dark:text-slate-300 mb-1">Message</label>
          <textarea id="feedback-message" rows="4" class="w-full px-3 py-2 rounded-lg bg-gray-100 dark:bg-slate-700 border border-gray-300 dark:border-slate-600 text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-slate-400" placeholder="Describe your feedback..."></textarea>
        </div>
        <div>
          <label class="block text-sm text-gray-700 dark:text-slate-300 mb-1">Email (optional)</label>
          <input type="email" id="feedback-email" class="w-full px-3 py-2 rounded-lg bg-gray-100 dark:bg-slate-700 border border-gray-300 dark:border-slate-600 text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-slate-400" placeholder="For reply" />
        </div>
        <button type="submit" class="w-full py-2 rounded-lg bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-500 hover:to-pink-500 font-medium transition-all">
          Send Feedback
        </button>
      </form>
      <div id="feedback-success" class="hidden text-center py-8">
        <div class="text-4xl mb-2">✅</div>
        <p class="text-green-600 dark:text-green-400 font-medium">Thank you for your feedback!</p>
      </div>
    </div>
  </div>


  <script define:vars={{ i18n, allLanguages, games, categoryI18nData }}>
    // All i18n data
    const translations = i18n
    const languageList = allLanguages
    const gameData = games
    const catI18n = categoryI18nData

    // Language names mapping
    const langNativeNames = {}
    languageList.forEach(l => { langNativeNames[l.code] = l.nativeName })

    // === Favorites & Recently Played Functions ===
    function getFavorites() {
      try {
        const data = localStorage.getItem('ruleword_favorites')
        return data ? JSON.parse(data) : []
      } catch (e) {
        return []
      }
    }

    function getRecentlyPlayed() {
      try {
        const data = localStorage.getItem('ruleword_recent')
        if (!data) return []
        const recent = JSON.parse(data)
        return recent
          .sort((a, b) => b.timestamp - a.timestamp)
          .slice(0, 12)
          .map(r => r.slug)
      } catch (e) {
        return []
      }
    }

    function createGameCard(game, lang) {
      const name = lang === 'zh-CN' || lang === 'zh-TW' ? game.nameZh : game.name
      const desc = lang === 'zh-CN' || lang === 'zh-TW' ? game.descZh : game.desc
      return `
        <a href="/games/${game.slug}/" class="group relative overflow-hidden rounded-xl p-4 text-center transition-all duration-300 hover:scale-[1.02] hover:shadow-lg bg-white dark:bg-slate-900/80 border border-gray-200 dark:border-slate-800 hover:border-gray-300 dark:hover:border-slate-600" data-game-slug="${game.slug}">
          <div class="${game.color} w-12 h-12 mx-auto rounded-xl flex items-center justify-center shadow-lg mb-2">
            <span class="text-2xl">${game.icon}</span>
          </div>
          <h4 class="font-medium text-gray-900 dark:text-white text-sm game-name truncate">${name}</h4>
          <p class="text-xs text-gray-500 dark:text-slate-500 mt-1 capitalize">${game.category}</p>
        </a>
      `
    }

    function renderFavorites(lang) {
      const favorites = getFavorites()
      const favoritesSection = document.getElementById('favorites-section')
      const favoritesGrid = document.getElementById('favorites-grid')

      if (favorites.length > 0) {
        favoritesSection.classList.remove('hidden')
        const favoriteGames = gameData.filter(g => favorites.includes(g.slug))
        favoritesGrid.innerHTML = favoriteGames.map(game => createGameCard(game, lang)).join('')
      } else {
        favoritesSection.classList.add('hidden')
      }
    }

    function renderRecentlyPlayed(lang) {
      const recent = getRecentlyPlayed()
      const recentSection = document.getElementById('recent-section')
      const recentGrid = document.getElementById('recent-grid')

      if (recent.length > 0) {
        recentSection.classList.remove('hidden')
        const recentGames = gameData.filter(g => recent.includes(g.slug))
        recentGrid.innerHTML = recentGames.map(game => createGameCard(game, lang)).join('')
      } else {
        recentSection.classList.add('hidden')
      }
    }

    function renderPersonalizedSections(lang) {
      renderFavorites(lang)
      renderRecentlyPlayed(lang)
    }

    // Clear favorites
    document.getElementById('clear-favorites-btn')?.addEventListener('click', () => {
      if (confirm('Remove all favorites?')) {
        localStorage.removeItem('ruleword_favorites')
        renderPersonalizedSections(getLang())
      }
    })

    // Clear recent
    document.getElementById('clear-recent-btn')?.addEventListener('click', () => {
      if (confirm('Clear recently played history?')) {
        localStorage.removeItem('ruleword_recent')
        renderPersonalizedSections(getLang())
      }
    })

    // Listen for changes
    window.addEventListener('favoritesChanged', () => renderPersonalizedSections(getLang()))
    window.addEventListener('recentlyPlayedChanged', () => renderPersonalizedSections(getLang()))

    // Get current language from URL or localStorage or browser
    function getLang() {
      const params = new URLSearchParams(window.location.search)
      const urlLang = params.get('lang')

      // Check if URL language is valid
      const validLangs = languageList.map(l => l.code)
      if (urlLang && validLangs.includes(urlLang)) {
        localStorage.setItem('ruleword-lang', urlLang)
        return urlLang
      }

      // Check localStorage
      const savedLang = localStorage.getItem('ruleword-lang')
      if (savedLang && validLangs.includes(savedLang)) {
        return savedLang
      }

      // Check browser language
      const browserLang = navigator.language || navigator.userLanguage
      if (browserLang) {
        if (browserLang.startsWith('zh-CN') || browserLang === 'zh-Hans') return 'zh-CN'
        if (browserLang.startsWith('zh-TW') || browserLang === 'zh-Hant' || browserLang.startsWith('zh-HK')) return 'zh-TW'
        if (browserLang.startsWith('zh')) return 'zh-CN'
        if (browserLang.startsWith('fr')) return 'fr'
        if (browserLang.startsWith('de')) return 'de'
        if (browserLang.startsWith('es')) return 'es'
        if (browserLang.startsWith('ru')) return 'ru'
        if (browserLang.startsWith('ja')) return 'ja'
      }

      return 'en'
    }

    // Set language (update content without changing URL to avoid duplicate pages)
    function setLang(lang) {
      localStorage.setItem('ruleword-lang', lang)
      applyTranslations(lang)
      renderPersonalizedSections(lang)
      // Update language button text
      const langObj = languageList.find(l => l.code === lang)
      const langText = document.getElementById('current-lang')
      if (langText && langObj) langText.textContent = langObj.nativeName
      // Close dropdown
      document.getElementById('lang-dropdown')?.classList.add('hidden')
    }
    window.setLang = setLang

    // Get game name by language
    function getGameNameByLang(game, lang) {
      if (lang === 'zh-CN' || lang === 'zh-TW') {
        return game.nameZh
      }
      return game.name
    }

    // Get game desc by language
    function getGameDescByLang(game, lang) {
      if (lang === 'zh-CN' || lang === 'zh-TW') {
        return game.descZh
      }
      return game.desc
    }

    // Apply translations
    function applyTranslations(lang) {
      const t = translations[lang] || translations['en']

      // Update i18n elements
      document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.getAttribute('data-i18n')
        if (t.home && t.home[key]) {
          el.textContent = t.home[key]
        } else if (t.nav && t.nav[key]) {
          el.textContent = t.nav[key]
        } else if (t[key]) {
          el.textContent = t[key]
        }
      })

      // Update game names and descriptions
      document.querySelectorAll('[data-game-slug]').forEach(el => {
        const slug = el.getAttribute('data-game-slug')
        const game = gameData.find(g => g.slug === slug)
        if (game) {
          const nameEl = el.querySelector('.game-name')
          const descEl = el.querySelector('.game-desc')
          if (nameEl) nameEl.textContent = getGameNameByLang(game, lang)
          if (descEl) descEl.textContent = getGameDescByLang(game, lang)
        }
      })

      // Update category names
      document.querySelectorAll('[data-category-id]').forEach(el => {
        const categoryId = el.getAttribute('data-category-id')
        const catNameEl = el.querySelector('.category-name')
        if (categoryId && catNameEl && catI18n[lang] && catI18n[lang][categoryId]) {
          catNameEl.textContent = catI18n[lang][categoryId].name
        }
      })

      // Update current lang button
      document.getElementById('current-lang').textContent = langNativeNames[lang] || 'English'

      // Update active state in dropdown
      document.querySelectorAll('[data-lang-code]').forEach(btn => {
        const code = btn.getAttribute('data-lang-code')
        if (code === lang) {
          btn.classList.add('text-green-400')
          btn.classList.remove('text-slate-300')
        } else {
          btn.classList.remove('text-green-400')
          btn.classList.add('text-slate-300')
        }
      })

      // Update personalized sections (favorites & recently played)
      renderPersonalizedSections(lang)
    }

    // Language dropdown toggle
    document.getElementById('lang-btn').addEventListener('click', () => {
      document.getElementById('lang-dropdown').classList.toggle('hidden')
    })

    // Close dropdown when clicking outside
    document.addEventListener('click', (e) => {
      if (!e.target.closest('#lang-btn') && !e.target.closest('#lang-dropdown')) {
        document.getElementById('lang-dropdown').classList.add('hidden')
      }
    })

    // Apply translations on load
    const currentLang = getLang()
    applyTranslations(currentLang)

    // Initialize personalized sections
    renderPersonalizedSections(currentLang)

    // Theme Toggle
    const themeToggleBtn = document.getElementById('theme-toggle-btn')
    const themeIcon = themeToggleBtn?.querySelector('.theme-icon')
    const themeText = themeToggleBtn?.querySelector('.theme-text')

    function updateThemeButton() {
      const isDark = document.documentElement.classList.contains('dark')
      if (themeIcon) themeIcon.textContent = isDark ? '🌙' : '☀️'
      if (themeText) themeText.textContent = isDark ? 'Dark' : 'Light'
    }

    themeToggleBtn?.addEventListener('click', () => {
      const html = document.documentElement
      const isDark = html.classList.contains('dark')

      if (isDark) {
        html.classList.remove('dark')
        localStorage.setItem('ruleword-theme', 'light')
      } else {
        html.classList.add('dark')
        localStorage.setItem('ruleword-theme', 'dark')
      }

      updateThemeButton()
    })

    // Initialize theme button
    updateThemeButton()

    // === All Games Tab Filtering ===
    const allGamesTabs = document.querySelectorAll('.all-games-tab')
    const allGamesCards = document.querySelectorAll('.game-card-all')

    allGamesTabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const filter = tab.dataset.filter
        allGamesTabs.forEach(t => {
          t.classList.remove('bg-green-600', 'text-white')
          t.classList.add('bg-gray-100', 'dark:bg-slate-800', 'text-gray-700', 'dark:text-slate-300')
        })
        tab.classList.remove('bg-gray-100', 'dark:bg-slate-800', 'text-gray-700', 'dark:text-slate-300')
        tab.classList.add('bg-green-600', 'text-white')
        allGamesCards.forEach(card => {
          card.style.display = (filter === 'all' || card.dataset.gameCategory === filter) ? '' : 'none'
        })
      })
    })

    // Feedback modal
    document.getElementById('feedback-btn')?.addEventListener('click', () => {
      document.getElementById('feedback-modal')?.classList.remove('hidden')
    })

    document.getElementById('feedback-form')?.addEventListener('submit', async (e) => {
      e.preventDefault()
      const form = e.target
      const submitBtn = form.querySelector('button[type="submit"]')

      submitBtn.disabled = true
      submitBtn.textContent = 'Sending...'

      const data = {
        type: document.getElementById('feedback-type').value,
        message: document.getElementById('feedback-message').value,
        email: document.getElementById('feedback-email').value,
      }

      try {
        const response = await fetch('https://api.emailjs.com/api/v1.0/email/send', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            service_id: 'service_2v1599e',
            template_id: 'template_9ee29rl',
            user_id: 'A73GlvN7cp09bDjon',
            template_params: {
              from_email: data.email || 'anonymous@ruleword.com',
              from_name: 'Free Games Hub User',
              message: `Type: ${data.type}\n\n${data.message}`,
            }
          })
        })

        if (response.ok) {
          form.classList.add('hidden')
          document.getElementById('feedback-success')?.classList.remove('hidden')
        } else {
          throw new Error('Failed to send')
        }
      } catch (err) {
        submitBtn.disabled = false
        submitBtn.textContent = 'Send Feedback'
        alert('Failed to send feedback. Please try again.')
      }
    })
  </script>
</BaseLayout>
