---
import BaseLayout from '../layouts/BaseLayout.astro'
import { getCollection } from 'astro:content'
import { languages, type Language } from '../data/i18n'

const urlLang = Astro.url.searchParams.get('lang') || 'en'
const lang: Language = languages.some(l => l.code === urlLang) ? (urlLang as Language) : 'en'
const isZh = lang === 'zh-CN'

const seoTitle = isZh ? '每日谜题挑战 - 每天玩新游戏 | Free Games Hub' : 'Daily Puzzle Challenge - Play a New Game Every Day | Free Games Hub'
const seoDescription = isZh
  ? '每天玩新的谜题挑战！7+ 个游戏含每日模式，包括四子棋、打砖块、15 拼图、熄灯等。免费在线玩，无需下载。'
  : 'Play a new puzzle challenge every day! 7+ games with daily modes including Connect Four, Brick Breaker, 15 Puzzle, Lights Out and more. Free online, no download.'

const breadcrumbItems = [
  { name: isZh ? '首页' : 'Home', url: '/' },
  { name: isZh ? '每日挑战' : 'Daily Challenge', url: '/daily/' },
]

const gamesCollection = await getCollection('games')
const allGames = gamesCollection.map(entry => entry.data)

const dailyGames = isZh ? [
  { slug: 'connect-four', dailyLabel: '每日AI对战', dailyDesc: '挑战今天的AI棋盘布局' },
  { slug: 'brick-breaker', dailyLabel: '每日打砖块', dailyDesc: '打碎今天的特殊砖块阵型' },
  { slug: '15-puzzle', dailyLabel: '每日推盘', dailyDesc: '解开今天的15数字推盘' },
  { slug: 'lights-out', dailyLabel: '每日熄灯', dailyDesc: '关掉今天的灯阵' },
  { slug: 'simon-says', dailyLabel: '每日记忆序列', dailyDesc: '记住今天的特殊序列' },
  { slug: 'tic-tac-toe', dailyLabel: '每日井字棋', dailyDesc: '在每日挑战中击败AI' },
  { slug: 'whack-a-mole', dailyLabel: '每日打地鼠', dailyDesc: '打今天的地鼠阵型' },
] : [
  { slug: 'connect-four', dailyLabel: 'Daily AI Match', dailyDesc: 'Challenge our AI in a new daily board setup' },
  { slug: 'brick-breaker', dailyLabel: 'Daily Brick Break', dailyDesc: "Break today's special brick pattern" },
  { slug: '15-puzzle', dailyLabel: 'Daily Slide', dailyDesc: "Solve today's shuffled 15-puzzle" },
  { slug: 'lights-out', dailyLabel: 'Daily Lights', dailyDesc: "Turn off all lights in today's pattern" },
  { slug: 'simon-says', dailyLabel: 'Daily Sequence', dailyDesc: "Remember today's special sequence" },
  { slug: 'tic-tac-toe', dailyLabel: 'Daily XO Match', dailyDesc: 'Beat the AI in today\'s daily challenge' },
  { slug: 'whack-a-mole', dailyLabel: 'Daily Whack', dailyDesc: "Whack today's special mole pattern" },
]

const dailyGameData = dailyGames.map(dg => {
  const game = allGames.find(g => g.slug === dg.slug)
  return {
    ...dg,
    name: isZh ? (game?.zh?.name || game?.en?.name || dg.slug) : (game?.en?.name || dg.slug),
    icon: game?.icon || '🎮',
    color: game?.color || 'from-blue-500 to-purple-600',
    desc: isZh ? (game?.zh?.desc || game?.en?.desc || '') : (game?.en?.desc || ''),
  }
})
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  keywords="daily puzzle, daily challenge, daily game, new puzzle every day, connect four daily, brick breaker daily, free daily games"
  canonicalPath="/daily/"
  ogImage="/og/daily.png"
  breadcrumbItems={breadcrumbItems}
>
  <div class="min-h-screen bg-gray-50 text-gray-900 dark:bg-slate-950 dark:text-white">
    <!-- Header -->
    <header class="sticky top-0 z-50 bg-white/90 dark:bg-slate-950/90 border-b border-gray-200 dark:border-slate-800 backdrop-blur-xl">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="flex items-center justify-between h-14">
          <a href={`/?lang=${lang}`} class="flex items-center gap-2 hover:opacity-80 transition-opacity">
            <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-green-400 to-emerald-600 flex items-center justify-center text-white font-bold text-sm shadow-lg">R</div>
            <span class="font-semibold hidden sm:inline">Free Games Hub</span>
          </a>
          <h1 class="text-lg font-bold">🗓️ {isZh ? '每日挑战' : 'Daily Challenge'}</h1>
          <div class="flex items-center gap-2">
            <a href="/daily/" class={`text-sm px-2 py-1 rounded ${lang === 'en' ? 'bg-amber-100 text-amber-700 font-semibold' : 'text-gray-500 hover:text-gray-700'}`}>EN</a>
            <a href="/daily/?lang=zh-CN" class={`text-sm px-2 py-1 rounded ${lang === 'zh-CN' ? 'bg-amber-100 text-amber-700 font-semibold' : 'text-gray-500 hover:text-gray-700'}`}>中文</a>
          </div>
        </div>
      </div>
    </header>

    <!-- Hero -->
    <div class="relative overflow-hidden bg-gradient-to-b from-amber-50 to-orange-50 dark:from-slate-900 dark:to-slate-950 py-12 px-4">
      <div class="absolute inset-0 overflow-hidden">
        <div class="absolute -top-40 -right-40 w-80 h-80 rounded-full blur-3xl opacity-20 bg-amber-500"></div>
        <div class="absolute -bottom-40 -left-40 w-80 h-80 rounded-full blur-3xl opacity-20 bg-orange-500"></div>
      </div>
      <div class="relative max-w-4xl mx-auto text-center">
        <div class="text-5xl mb-4">📅</div>
        <h2 class="text-3xl sm:text-4xl font-bold mb-3">{isZh ? '每日谜题挑战' : 'Daily Puzzle Challenge'}</h2>
        <p class="text-lg text-gray-600 dark:text-slate-400 max-w-2xl mx-auto mb-4">
          {isZh ? '每天一个全新挑战！7个不同的每日谜题——每个都在午夜重置为全新的谜题。' : 'A fresh challenge every day! Play 7 different daily puzzles — each one resets at midnight with a brand new puzzle to solve.'}
        </p>
        <div class="flex flex-wrap justify-center gap-3 text-sm">
          <span class="px-3 py-1 bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-300 rounded-full font-medium">🔄 {isZh ? '每日重置' : 'Resets Daily'}</span>
          <span class="px-3 py-1 bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 rounded-full font-medium">🧠 7 {isZh ? '个游戏' : 'Games'}</span>
          <span class="px-3 py-1 bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300 rounded-full font-medium">🆓 {isZh ? '永久免费' : 'Free Forever'}</span>
        </div>
      </div>
    </div>

    <!-- Daily Games Grid -->
    <section class="max-w-5xl mx-auto px-4 py-12">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {dailyGameData.map(game => (
          <a
            href={`/games/${game.slug}/?mode=daily`}
            class="group block bg-white dark:bg-slate-900/80 border border-gray-200 dark:border-slate-800 hover:border-amber-400 dark:hover:border-amber-500 rounded-2xl overflow-hidden transition-all duration-300 hover:shadow-lg hover:shadow-amber-500/10 hover:scale-[1.02]"
          >
            <div class={`h-2 bg-gradient-to-r ${game.color}`} />
            <div class="p-6">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-3xl">{game.icon}</span>
                <div>
                  <h3 class="font-bold text-gray-900 dark:text-white group-hover:text-amber-600 dark:group-hover:text-amber-400 transition-colors">{game.dailyLabel}</h3>
                  <span class="text-xs text-gray-500 dark:text-slate-500 uppercase tracking-wider">{game.name}</span>
                </div>
              </div>
              <p class="text-sm text-gray-600 dark:text-slate-400 mb-4">{game.dailyDesc}</p>
              <div class="flex items-center justify-between">
                <span class="text-xs text-amber-600 dark:text-amber-400 font-medium">📅 New puzzle today</span>
                <span class="inline-block px-3 py-1 bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-300 rounded-lg text-sm group-hover:bg-amber-200 dark:group-hover:bg-amber-900/50 transition-colors">
                  Play Now →
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- How It Works -->
    <section class="bg-white dark:bg-slate-900/50 border-t border-gray-200 dark:border-slate-800 py-12 px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl font-bold text-center mb-8">{isZh ? '每日挑战如何运作' : 'How Daily Challenges Work'}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
          <div class="text-center">
            <div class="text-3xl mb-3">🌅</div>
            <h3 class="font-semibold mb-2">{isZh ? '每天新谜题' : 'New Puzzle Every Day'}</h3>
            <p class="text-sm text-gray-600 dark:text-slate-400">{isZh ? '每个游戏根据今天的日期生成独特的谜题。每个人都得到相同的挑战！' : "Each game generates a unique puzzle based on today's date. Everyone gets the same challenge!"}</p>
          </div>
          <div class="text-center">
            <div class="text-3xl mb-3">🏆</div>
            <h3 class="font-semibold mb-2">{isZh ? '追踪你的分数' : 'Track Your Score'}</h3>
            <p class="text-sm text-gray-600 dark:text-slate-400">{isZh ? '完成每日谜题并追踪你的分数。明天再来挑战新的！' : 'Complete the daily puzzle and track your score. Come back tomorrow for a fresh challenge.'}</p>
          </div>
          <div class="text-center">
            <div class="text-3xl mb-3">🔄</div>
            <h3 class="font-semibold mb-2">{isZh ? '午夜重置' : 'Resets at Midnight'}</h3>
            <p class="text-sm text-gray-600 dark:text-slate-400">{isZh ? '每日挑战每晚午夜重置。不要错过今天的谜题！' : "Daily challenges reset every night at midnight. Don't miss today's puzzle!"}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="border-t border-gray-200 dark:border-slate-800 py-12 px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl font-bold text-center mb-6">{isZh ? '常见问题' : 'Frequently Asked Questions'}</h2>
        <div class="space-y-4">
          <details class="group bg-white dark:bg-slate-900/50 rounded-lg border border-gray-200 dark:border-slate-800">
            <summary class="px-4 py-3 cursor-pointer font-medium hover:text-amber-600 dark:hover:text-amber-400 transition-colors">
              {isZh ? '什么是每日挑战？' : 'What is the Daily Challenge?'}
            </summary>
            <p class="px-4 pb-3 text-gray-600 dark:text-slate-400 text-sm">{isZh ? '每日挑战是每天变化的特殊谜题变体。每个游戏根据当前日期生成独特的谜题，所以每个人都得到相同的挑战。这是每天测试你技能的好方法！' : 'Daily Challenges are special puzzle variants that change every day. Each game generates a unique puzzle based on the current date, so everyone gets the same challenge. It\'s a great way to test your skills against a fresh puzzle each day!'}</p>
          </details>
          <details class="group bg-white dark:bg-slate-900/50 rounded-lg border border-gray-200 dark:border-slate-800">
            <summary class="px-4 py-3 cursor-pointer font-medium hover:text-amber-600 dark:hover:text-amber-400 transition-colors">
              {isZh ? '每日谜题什么时候重置？' : 'When does the daily puzzle reset?'}
            </summary>
            <p class="px-4 pb-3 text-gray-600 dark:text-slate-400 text-sm">{isZh ? '每日谜题每晚在你当地时区的午夜重置。午夜之后，每个游戏都会有全新的谜题。每天的谜题只能玩一次并记录分数。' : "Daily puzzles reset every night at midnight in your local timezone. After midnight, you'll get a brand new puzzle for each game. You can only play each day's puzzle once for a score."}</p>
          </details>
          <details class="group bg-white dark:bg-slate-900/50 rounded-lg border border-gray-200 dark:border-slate-800">
            <summary class="px-4 py-3 cursor-pointer font-medium hover:text-amber-600 dark:hover:text-amber-400 transition-colors">
              {isZh ? '可以玩以前的每日谜题吗？' : 'Can I play old daily puzzles?'}
            </summary>
            <p class="px-4 pb-3 text-gray-600 dark:text-slate-400 text-sm">{isZh ? '目前只有今天的每日谜题可用。每天都会带来新的挑战——错过一天也有新的等着你！这鼓励每日参与，保持新鲜感。' : "Currently, only today's daily puzzle is available. Each day brings a new challenge — miss a day and there's a fresh one waiting! This encourages daily engagement and keeps things exciting."}</p>
          </details>
          <details class="group bg-white dark:bg-slate-900/50 rounded-lg border border-gray-200 dark:border-slate-800">
            <summary class="px-4 py-3 cursor-pointer font-medium hover:text-amber-600 dark:hover:text-amber-400 transition-colors">
              {isZh ? '每日挑战免费吗？' : 'Are daily challenges free?'}
            </summary>
            <p class="px-4 pb-3 text-gray-600 dark:text-slate-400 text-sm">{isZh ? '完全免费！所有每日挑战都完全免费。无需注册、无需下载、无需付费。点击即玩！' : 'Absolutely! All daily challenges are completely free. No registration, no download, no payment required. Just click and play!'}</p>
          </details>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="bg-white dark:bg-slate-900 border-t border-gray-200 dark:border-slate-800 py-4 px-4 text-center text-sm text-gray-500 dark:text-slate-500">
      © 2026 Free Games Hub — <a href={`/?lang=${lang}`} class="text-emerald-600 dark:text-emerald-400 hover:underline">{isZh ? '免费在线游戏' : 'Play Free Online Games'}</a>
    </footer>
  </div>
</BaseLayout>