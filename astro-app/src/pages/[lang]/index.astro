---
// Language-specific homepage - Redirect to main site with language cookie
import { languages } from '../../../astro.config.mjs'

export function getStaticPaths() {
  return Object.keys(languages).map(lang => ({
    params: { lang },
  }))
}

const { lang } = Astro.params
const langName = languages[lang]
---

<html>
<head>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="canonical" href="https://ruleword.com/" />
  <meta http-equiv="refresh" content="0;url=/" />
  <title>Redirecting to {langName}...</title>
  <script define:vars={{ lang }}>
    // Set language preference and redirect
    document.cookie = "preferred-language=" + lang + ";path=/;max-age=31536000";
    localStorage.setItem("ruleword-lang", lang);
    window.location.href = "/";
  </script>
</head>
<body>
  <p>Redirecting to {langName}...</p>
</body>
</html>
