---
// Language-specific game page - Redirect to main game with language parameter
import { languages } from '../../../../astro.config.mjs'
import { games } from '../../../data/games'

export function getStaticPaths() {
  const paths = []
  for (const lang of Object.keys(languages)) {
    for (const game of games) {
      paths.push({
        params: { lang, slug: game.id },
      })
    }
  }
  return paths
}

const { lang, slug } = Astro.params
const game = games.find(g => g.id === slug)

if (!game) {
  return Astro.redirect('/404')
}

const redirectUrl = `/games/${slug}/?lang=${lang}`
---

<html>
<head>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="canonical" href={`https://ruleword.com/games/${slug}/`} />
  <meta http-equiv="refresh" content={`0;url=/games/${slug}/`} />
  <title>{game.name} - Redirecting...</title>
  <script define:vars={{ lang, slug }}>
    // Set language preference and redirect to game
    document.cookie = "preferred-language=" + lang + ";path=/;max-age=31536000";
    localStorage.setItem("ruleword-lang", lang);
    window.location.href = "/games/" + slug + "/";
  </script>
</head>
<body>
  <p>Redirecting to {game.name}...</p>
</body>
</html>
