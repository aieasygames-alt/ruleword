---
// Topic Hubs Index Page
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getAllHubSlugs, getHubPage } from '../../data/hubPages'

const hubs = getAllHubSlugs().map(slug => getHubPage(slug)!)

const hubIcons: Record<string, string> = {
  'word-games': '📝',
  'number-puzzles': '🔢',
  'japanese-logic': '🇯🇵',
  'brain-training': '🧠',
  'memory-games': '🎴',
  'strategy-games': '♟️'
}

const hubColors: Record<string, string> = {
  'word-games': 'from-blue-500 to-indigo-600',
  'number-puzzles': 'from-green-500 to-emerald-600',
  'japanese-logic': 'from-red-500 to-pink-600',
  'brain-training': 'from-purple-500 to-violet-600',
  'memory-games': 'from-amber-500 to-orange-600',
  'strategy-games': 'from-cyan-500 to-teal-600'
}
---

<BaseLayout title="Game Collections - Browse by Category | Free Games Hub" description="Explore curated collections of puzzle games by category. Word games, number puzzles, Japanese logic, brain training, memory games, and strategy games.">
  <div class="min-h-screen bg-slate-950 text-white">
    <!-- Header -->
    <header class="sticky top-0 z-50 bg-slate-950/90 border-b border-slate-800 backdrop-blur-xl">
      <div class="max-w-4xl mx-auto px-4 sm:px-6">
        <div class="flex items-center justify-between h-14">
          <a href="/" class="flex items-center gap-2 hover:opacity-80 transition-opacity">
            <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-green-400 to-emerald-600 flex items-center justify-center text-white font-bold text-sm shadow-lg">
              R
            </div>
            <span class="font-semibold">Free Games Hub</span>
          </a>
          <a href="/" class="text-sm text-slate-400 hover:text-white transition-colors">
            ← Back to Games
          </a>
        </div>
      </div>
    </header>

    <!-- Hero -->
    <main class="max-w-4xl mx-auto px-4 sm:px-6 py-8 sm:py-12">
      <div class="text-center mb-12">
        <h1 class="text-3xl sm:text-4xl font-bold mb-4 bg-gradient-to-r from-green-400 to-emerald-500 bg-clip-text text-transparent">
          Game Collections
        </h1>
        <p class="text-lg text-slate-300 max-w-2xl mx-auto">
          Explore our curated collections of the best free online games.
          Each collection features hand-picked games, guides, and tips.
        </p>
      </div>

      <!-- Hub Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {hubs.map(hub => (
          <a
            href={`/hubs/${hub.slug}/`}
            class="group bg-gradient-to-br from-slate-900 to-slate-800 border border-slate-700 rounded-2xl p-6 hover:border-slate-500 transition-all hover:-translate-y-1"
          >
            <div class="flex items-start gap-4">
              <div class={`w-14 h-14 rounded-xl bg-gradient-to-br ${hubColors[hub.slug]} flex items-center justify-center text-2xl shadow-lg`}>
                {hubIcons[hub.slug]}
              </div>
              <div class="flex-1">
                <h2 class="text-xl font-bold group-hover:text-green-400 transition-colors mb-2">
                  {hub.title.split(' - ')[0]}
                </h2>
                <p class="text-sm text-slate-400 line-clamp-2 mb-3">
                  {hub.description}
                </p>
              </div>
              <svg class="w-5 h-5 text-slate-600 group-hover:text-green-400 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </div>
          </a>
        ))}
      </div>

      <!-- CTA -->
      <div class="mt-12 bg-gradient-to-r from-green-900/30 to-emerald-900/30 border border-green-700/50 rounded-2xl p-8 text-center">
        <h2 class="text-2xl font-bold mb-3">Looking for a Specific Game?</h2>
        <p class="text-slate-300 mb-6">
          Browse all 112+ games on our homepage, organized by category.
        </p>
        <a
          href="/"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-gradient-to-r from-green-500 to-emerald-600 hover:from-green-400 hover:to-emerald-500 font-medium transition-all"
        >
          <span>🎮</span>
          View All Games
        </a>
      </div>
    </main>

    <!-- Footer -->
    <footer class="border-t border-slate-800 py-6 px-4">
      <div class="max-w-4xl mx-auto text-center text-sm text-slate-400">
        <p>© 2026 Free Games Hub · Free Online Games</p>
      </div>
    </footer>
  </div>
</BaseLayout>
