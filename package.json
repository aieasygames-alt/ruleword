{
  "name": "ruleword",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "cd astro-app && pnpm dev",
    "build": "rm -rf dist && cd astro-app && npm install && npm run build && cp -r dist ../dist",
